# Cloudflare Pages headers. Hashed build assets + fonts are content-addressed → cache forever.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/chart-kit.js
  Cache-Control: public, max-age=86400

/article-actions.js
  Cache-Control: public, max-age=86400

/articles/*/charts/*
  Cache-Control: public, max-age=86400

/og-default.png
  Cache-Control: public, max-age=604800
/og/articles/*
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/maskable-192.png
  Cache-Control: public, max-age=604800
/maskable-512.png
  Cache-Control: public, max-age=604800

# Service worker must always revalidate so a new version ships on the next visit —
# never let it get pinned in the HTTP cache.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/pwa.js
  Cache-Control: public, max-age=86400
/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400

# The api-catalog must be served as a linkset with the RFC 9727 profile.
/.well-known/api-catalog
  Content-Type: application/linkset+json; profile="https://www.rfc-editor.org/info/rfc9727"
  Cache-Control: public, max-age=86400

# Security headers + agent-discovery Link headers for every response.
# (No cache directive here, so HTML keeps Pages' revalidating default.)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com; form-action 'self'; upgrade-insecure-requests
  Link: </sitemap.xml>; rel="sitemap"; type="application/xml", </.well-known/api-catalog>; rel="api-catalog", </llms.txt>; rel="alternate"; type="text/plain"; title="LLM index"
