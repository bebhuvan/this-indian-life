{
  "schemaVersion": 1,
  "updatedAt": "2026-06-02",
  "policy": {
    "production_no_secret": "Runs only jobs that do not require API keys or credentials. Jobs write snapshots/manifests/artifacts and then run validation.",
    "discovery_no_secret": "Refreshes public discovery catalogs. Discovery output is not article evidence until a production ingest promotes it.",
    "validation": "Runs validators and build checks without fetching source data."
  },
  "jobs": [
    {
      "jobId": "discover-rbi-dbie",
      "sourceId": "rbi-dbie",
      "kind": "discovery",
      "cadence": "weekly",
      "groups": ["discovery_no_secret"],
      "command": ["npm", "run", "discover:rbi-dbie"],
      "requiredEnv": [],
      "writes": ["data/catalog/rbi-dbie-discovery.json"],
      "evidenceEligible": false
    },
    {
      "jobId": "discover-rbi-dbie-reports",
      "sourceId": "rbi-dbie",
      "kind": "discovery",
      "cadence": "weekly",
      "groups": ["production_no_secret", "discovery_no_secret"],
      "command": ["npm", "run", "discover:rbi-dbie-reports"],
      "requiredEnv": [],
      "writes": ["data/catalog/rbi-dbie-report-inventory.json"],
      "evidenceEligible": false
    },
    {
