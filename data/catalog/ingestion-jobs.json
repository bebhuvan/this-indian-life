    {
      "jobId": "ingest-rbi-dbie-forex-reserves",
      "sourceId": "rbi-dbie",
      "kind": "ingest",
      "cadence": "weekly",
      "groups": ["production_no_secret"],
      "command": ["npm", "run", "ingest:rbi-dbie-forex-reserves"],
      "requiredEnv": [],
      "writes": [
        "data/catalog/rbi-dbie-manifest.json",
        "data/series/rbi-dbie.IN.forex_reserves.weekly.json"
      ],
      "evidenceEligible": true,
      "qualityGates": [
        "non-empty output per currency/reserve code",
        "date/code/unit validation",
        "TR reconciled against FCA + GOLD + SDR + IMF within 0.01%"
      ]
    },
    {
      "jobId": "ingest-rbi-dbie-macro-timeseries",
      "sourceId": "rbi-dbie",
      "kind": "ingest",
      "cadence": "weekly",
      "groups": ["production_no_secret"],
      "command": ["npm", "run", "ingest:rbi-dbie-macro-timeseries"],
      "requiredEnv": [],
      "writes": [
        "data/catalog/rbi-dbie-manifest.json",
        "data/series/rbi-dbie.IN.macro_50_indicators.long.json",
        "data/series/rbi-dbie.IN.macro_other_timeseries.long.json"
      ],
      "evidenceEligible": true,
      "qualityGates": [
        "official RBI XLSX workbook snapshot retained",
        "expected sheet names and minimum row counts",
        "finite numeric values only",
        "no duplicate dataset/frequency/period/indicator keys",
        "foreign currency assets reconciled against RBI forex reserves artifact when present"
      ]
    },
    {
      "jobId": "derive-rbi-dbie-macro-series",
      "sourceId": "rbi-dbie",
      "kind": "transform",
      "cadence": "weekly",
      "groups": ["production_no_secret"],
      "command": ["npm", "run", "derive:rbi-dbie-macro-series"],
      "requiredEnv": [],
      "writes": [
        "data/catalog/rbi-dbie-manifest.json",
        "data/catalog/rbi-dbie-derived-series.json"
      ],
      "evidenceEligible": true,
      "dependsOn": ["ingest-rbi-dbie-macro-timeseries"],
      "qualityGates": [
        "exact parent artifact label/frequency/unit match",
        "finite numeric values only",
        "unique period keys per derived series",
        "minimum observation count per selected indicator",
        "parent artifact hash recorded in child metadata"
      ]
    },
    {
      "jobId": "ingest-who-gho",
      "sourceId": "who-gho",
      "kind": "ingest",
      "cadence": "monthly",
      "groups": ["production_no_secret"],
