    {
      "jobId": "ingest-trai-subscriptions",
      "sourceId": "trai",
      "kind": "ingest",
      "cadence": "monthly",
      "groups": ["production_no_secret"],
      "command": ["npm", "run", "ingest:trai-subscriptions", "--", "--limit", "12", "--ocr-fallback"],
      "requiredEnv": [],
      "writes": [
        "data/catalog/trai-subscriptions-manifest.json",
        "data/series/trai.IN.telecom_subscribers_total.json",
        "data/series/trai.IN.telecom_subscribers_wireless.json",
        "data/series/trai.IN.telecom_subscribers_wireline.json",
        "data/series/trai.IN.telecom_subscribers_urban_total.json",
        "data/series/trai.IN.telecom_subscribers_rural_total.json",
        "data/series/trai.IN.broadband_subscribers_total.json",
        "data/series/trai.IN.teledensity_total.json",
        "data/series/trai.IN.active_wireless_mobile_subscribers_peak_vlr.json",
        "data/series/trai.IN.mobile_number_portability_requests.json"
      ],
      "evidenceEligible": true,
      "qualityGates": [
        "official TRAI monthly report PDF snapshot retained",
        "native PDF text parser used before OCR fallback",
        "Paddle/Akshara structure OCR fallback available for image-only reports",
        "required telecom, broadband, teledensity, active wireless, and MNP rows present",
        "subscriber totals reconcile wireless plus wireline where report rows expose components",
        "teledensity totals reconcile wireless plus wireline within tolerance",
        "suspicious month-to-month jumps flagged by validator"
      ]
    },
