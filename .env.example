# Copy this file to .env and fill only the keys you actually use.
# .env is gitignored. Do not commit real secrets.

# LLM providers used only in offline ingest/explanation generation.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Data APIs.
INDIA_DATA_HUB_API_KEY=
FRED_API_KEY=
EMBER_API_KEY=
WAQI_API_KEY=
EIA_API_KEY=
UN_COMTRADE_API_KEY=
# Aliases also accepted: COMTRADE_API_KEY, COMTRADE_SUBSCRIPTION_KEY,
# UN_COMTRADE_SUBSCRIPTION_KEY.
# WTO Timeseries API: subscribe to the free "Standard" product at
# apiportal.wto.org, then copy the Primary key from your Profile page.
WTO_API_KEY=
OPENAQ_API_KEY=
DATA_GOV_IN_API_KEY=
CDSAPI_KEY=
# Alias accepted for your existing local env naming:
# copernicus=
CDSAPI_URL=https://cds.climate.copernicus.eu/api

# Public build-time analytics token from Cloudflare Web Analytics > Manage site.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Optional base URLs / knobs for adapters.
INDIA_DATA_HUB_BASE_URL=https://feeds.indiadatahub.com
FRED_BASE_URL=https://api.stlouisfed.org/fred
EMBER_BASE_URL=https://api.ember-energy.org/v1
EIA_BASE_URL=https://api.eia.gov/v2
PPAC_BASE_URL=https://ppac.gov.in
UN_COMTRADE_BASE_URL=https://comtradeapi.un.org
WTO_BASE_URL=https://api.wto.org/timeseries/v1
WAQI_BASE_URL=https://api.waqi.info
OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com
OPENAQ_BASE_URL=https://api.openaq.org
DEEPSEEK_BASE_URL=https://api.deepseek.com
INDICA_EXPLANATION_MODEL=deepseek-v4-flash
OWID_BASE_URL=https://ourworldindata.org
WORLD_BANK_DOCUMENTS_BASE_URL=https://search.worldbank.org/api/v3/wds
WORLD_BANK_DATA360_BASE_URL=https://data360api.worldbank.org
NDAP_BASE_URL=https://loadqa.ndapapi.com
DATA_PORTAL_CITIES_BASE_URL=https://dataportalforcities.org
OECD_BASE_URL=https://sdmx.oecd.org
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api
UN_POPULATION_BASE_URL=https://population.un.org/dataportalapi
UN_POPULATION_BEARER_TOKEN=

# Ingest behavior.
INDICA_INGEST_DRY_RUN=false
INDICA_SNAPSHOT_RAW=true
INDICA_FETCH_TIMEOUT_MS=30000
EIA_FETCH_TIMEOUT_MS=90000
EIA_FETCH_RETRIES=3
EIA_RETRY_DELAY_MS=3000
UN_COMTRADE_PERIOD=2024
UN_COMTRADE_ENDPOINT=public/v1/preview
UN_COMTRADE_FETCH_TIMEOUT_MS=90000
UN_COMTRADE_FETCH_RETRIES=2
UN_COMTRADE_RETRY_DELAY_MS=3000
OPEN_METEO_START_DATE=1940-01-01
# Leave blank to fetch through today minus OPEN_METEO_DELAY_DAYS.
OPEN_METEO_END_DATE=
OPEN_METEO_DELAY_DAYS=7
OPEN_METEO_MODEL=era5
OPEN_METEO_FETCH_TIMEOUT_MS=120000
OPEN_METEO_FETCH_RETRIES=4
OPEN_METEO_RETRY_DELAY_MS=10000
OPEN_METEO_CITY_DELAY_MS=15000
# Optional comma-separated subset for retries, e.g. kolkata,bengaluru.
OPEN_METEO_CITY_IDS=
INDICA_DEEPSEEK_TIMEOUT_MS=90000
INDICA_EXPLANATION_MAX_TOKENS=7000
