---
import "../styles/indica.css";

type Props = {
  title?: string;
  description?: string;
  domain?: string;
};

const {
  title = "Indica · A Living Almanac of India",
  description = "Sourced charts and plain-language explanations about how India lives.",
  domain
} = Astro.props;
const bodyClass = domain ? `dom-${domain}` : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>

