---
import Base from "../layouts/Base.astro";
import Nav from "./Nav.astro";
import { charts, chartUrl, domains, formatValue, latestObservation, loadSeries } from "../data/site";

const locale = "en";
const featured = charts.find((chart) => chart.id === "people.population.total")!;
const featuredSeries = loadSeries(featured.seriesPath);
const featuredLatest = latestObservation(featuredSeries)!;
const ledger = charts
  .filter((chart) => ["people.population.total", "econ.gdp.current_usd", "energy.electricity_access", "health.life_expectancy"].includes(chart.id))
  .map((chart) => {
    const latest = latestObservation(loadSeries(chart.seriesPath))!;
    return { chart, latest };
  });
---

<Base>
  <div class="wrap">
    <Nav active="people" locale={locale} />

    <div class="home-kicker">
      <span class="lbl">India - A Living Almanac</span>
      <span class="lbl">Static-first · sourced · no runtime API calls</span>
    </div>

    <section class="dom-people home-hero">
      <div class="hero-num-row">
        <span class="hero-num">{formatValue(featuredLatest.value, featured.valueFormat).replace(" bn", "")}<span class="u"> bn</span></span>
        <div class="hero-aside">
          <span class="lbl">People · {featuredLatest.date}</span>
          <span class="cat serif">A country large enough to bend every average</span>
        </div>
      </div>
      <div class="demo home-chips">
        <span class="chip">World Bank seed data</span>
        <span class="chip">7 live chart artifacts</span>
        <span class="chip">RBI + MoSPI next</span>
      </div>
      <h1 class="serif home-title">Every question about India, answered in numbers and explained in plain language.</h1>
      <p class="muted home-dek">
        Indica pulls scattered public data into sourced chart pages: the number, the context,
        the caveat, and the plain-English reading. The first build is wired to normalized data artifacts,
        not mocks.
      </p>
      <a class="btn dom-people" href="/en/ask/">Ask a question</a>
    </section>

    <section class="section" style="border-bottom:1px solid var(--ghost)">
      <div class="ledger-grid">
        {ledger.map(({ chart, latest }) => (
          <a class={`li dom-${chart.domain} ledger-link`} href={chartUrl(chart, locale)}>
            <span class="li-n">{formatValue(latest.value, chart.valueFormat)}</span>
            <p class="li-lbl"><span class="tk"></span>{chart.shortTitle}</p>
            <p class="li-cut">{chart.bottomLine}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="sec-hd">Browse by domain</p>
      <div class="cards">
        {domains.map((domain) => {
          const count = charts.filter((chart) => chart.domain === domain.id).length;
          return (
            <a class={`card dom-${domain.id}`} href={`/${locale}/${domain.id}/`}>
              <div class="tag">{domain.label}</div>
              <h4>{domain.line}</h4>
              <p class="sub">{count} live chart{count === 1 ? "" : "s"} in the seed catalog</p>
              <span class="arrow">-></span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="section">
      <p class="sec-hd">Starter questions</p>
      <div>
        {charts.slice(0, 6).map((chart) => {
          const latest = latestObservation(loadSeries(chart.seriesPath))!;
          return (
            <a class="q-row" href={chartUrl(chart, locale)}>
              <span class="q-dot" style={`background:var(--${chart.domain})`}></span>
              <span class="q-txt">{chart.title}</span>
              <span class="q-ans" style={`color:var(--${chart.domain})`}>{formatValue(latest.value, chart.valueFormat)}</span>
              <span class="q-arrow">-></span>
            </a>
          );
        })}
      </div>
    </section>

    <footer class="foot">
      <div class="foot-brand">Indica</div>
      <p class="foot-note">
        Seed data source: World Bank Indicators API. Architecture is ready for RBI, MoSPI,
        India Data Hub, OpenAQ/WAQI, NASA POWER, OWID, and survey datasets.
      </p>
    </footer>
  </div>
</Base>

