---
import Base from "../layouts/Base.astro";
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import { charts, domains, formatValue, latestObservation, loadSeries } from "../data/site";
import { questionPages, questionUrl, statusMeta } from "../data/questions";
import { homeGraph } from "../data/seo";

type Props = { canonicalPath?: string };
const { canonicalPath } = Astro.props;
const locale = "en";
const featured = charts.find((chart) => chart.id === "people.population.total")!;
const featuredSeries = loadSeries(featured.seriesPath);
const featuredLatest = latestObservation(featuredSeries)!;
// Resolve the article behind a stat tile. Prefer the exact same-question article (slug
// match — catches cases like GDP where the chart's indicator differs from the article's),
// then fall back to any article that charts this indicator (core/context/visualPlan).
const findArticle = (chart: (typeof charts)[number]) =>
  questionPages.find((page) => page.slug === chart.slug) ??
  questionPages.find(
    (page) =>
      page.indicators.includes(chart.id) ||
      (page.core ?? []).includes(chart.id) ||
      (page.context ?? []).includes(chart.id) ||
      (page.visualPlan ?? []).some(
        (entry) => entry.indicator === chart.id || (entry.series ?? []).some((s) => s.indicator === chart.id)
      )
  );
// The homepage GDP headline shows the IMF WEO (April 2026) figure — India ~$4.15T
// in 2026, the most current "size of the economy" number — because the World Bank
// series only runs through 2024 (~$3.91T) and the ingested IMF series stops at the
// 2025 estimate. The article's 1960→ historical chart still uses World Bank.
// Source: IMF World Economic Outlook (Apr 2026), NGDPD/IND.
const GDP_IMF_LATEST = { date: "2026", value: 4.15e12 };
const ledger = charts
  .filter((chart) => ["people.population.total", "econ.gdp.current_usd", "energy.electricity_access", "health.life_expectancy"].includes(chart.id))
  .map((chart) => {
    const latest =
      chart.id === "econ.gdp.current_usd"
        ? GDP_IMF_LATEST
        : latestObservation(loadSeries(chart.seriesPath))!;
    const article = findArticle(chart);
    return { chart, latest, href: article ? questionUrl(article, locale) : `/articles/` };
  });
---

<Base jsonLd={homeGraph()} canonicalPath={canonicalPath}>
  <div class="wrap">
    <Nav active="people" locale={locale} />

    <div class="home-kicker">
      <span class="lbl">All our lives, in numbers</span>
    </div>

    <section class="dom-people home-hero">
      <div class="hero-num-row">
        <span class="hero-num">{formatValue(featuredLatest.value, featured.valueFormat).replace(" bn", "")}<span class="u"> bn</span></span>
        <div class="hero-aside">
          <span class="lbl">People · {featuredLatest.date}</span>
          <span class="cat serif">A country large enough to bend every average</span>
        </div>
      </div>
      <h1 class="serif home-title">India isn't one country. It's many, wearing a single name.</h1>
      <p class="muted home-dek">
        Big questions about how Indians actually live — answered from sourced numbers, in plain language.
      </p>
      <a class="btn dom-people" href="/ask/">Ask a question</a>
    </section>

    <section class="section" style="border-bottom:1px solid var(--ghost)">
      <div class="ledger-grid">
        {ledger.map(({ chart, latest, href }) => (
          <a class={`li dom-${chart.domain} ledger-link`} href={href}>
            <span class="li-n">{formatValue(latest.value, chart.valueFormat)}</span>
            <p class="li-lbl"><span class="tk"></span>{chart.shortTitle}</p>
            <p class="li-cut">{chart.bottomLine}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="sec-hd">Browse by domain</p>
      <div class="cards">
        {domains.map((domain) => {
          const count = questionPages.filter((page) => page.domain === domain.id).length;
          return (
            <a class={`card dom-${domain.id}`} href={`/${domain.id}/`}>
              <div class="tag">{domain.label}</div>
              <h2>{domain.line}</h2>
              <p class="sub">{count} independent question page{count === 1 ? "" : "s"}</p>
              <span class="arrow">-></span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="section">
      <p class="sec-hd">Starter questions</p>
      <div>
        {questionPages.slice(0, 10).map((page) => {
          return (
            <a class="q-row" href={questionUrl(page, locale)}>
              <span class="q-dot" style={`background:var(--${page.domain})`}></span>
              <span class="q-txt">{page.question}</span>
              <span class="q-ans" style={`color:var(--${page.domain}-ink)`}>{statusMeta(page.explanation.status).short}</span>
              <span class="q-arrow">-></span>
            </a>
          );
        })}
      </div>
    </section>

    <Footer locale={locale} />
  </div>
</Base>
