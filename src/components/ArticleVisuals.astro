---
import type { VisualSpec, LineVisual, LinePanelsVisual, StackVisual, BarVisual, GroupedBarVisual, ChangeVisual, PyramidVisual, StripeVisual, ChoroplethVisual, ScatterVisual, StripPairVisual, ScenarioMapsVisual, SparkGridVisual, RankedChangeVisual } from "../data/viz";
import type { LockedNumber } from "../data/questions";
import { formatLockedNumber } from "../data/questions";
import { fileSafe } from "../data/chartDownloads";
import { choroColor, compactSvgPath, choroplethValueLabel, renderChoroplethSvg, viewBoxAspectRatio } from "../data/chartSvg";

type ChartExplainer = {
  visualId: string;
  title: string;
  takeaway?: string;
  detail?: string;
  whyShowThis: string;
  howToRead: string;
  mistakeToAvoid: string;
  mobileNote: string;
};

type Props = {
  visuals: VisualSpec[];
  lockedNumbers?: LockedNumber[];
  chartExplainers?: ChartExplainer[];
  showKpis?: boolean;
  leadFirst?: boolean;
  startIndex?: number;
  sectionLabel?: string;
  sectionClass?: string;
};

const {
  visuals,
  lockedNumbers = [],
  chartExplainers = [],
  showKpis = true,
  leadFirst = true,
  startIndex = 0,
  sectionLabel = "The data",
  sectionClass = ""
} = Astro.props;

// Coral (domain ink) + near-black lead, then softened, harmonised secondaries so
// multi-line charts read calm rather than rainbow-loud (riso-ink, bright-but-soft).
const colors = ["var(--c)", "#0b0b0b", "#3f8378", "#cf9a3f", "#7e6ba6", "#b5765c", "#8c8780"];
const sourceNames: Record<string, string> = {
  worldbank: "World Bank",
  "un-population": "UN Population",
  "who-gho": "WHO GHO",
  indiadatahub: "IndiaDataHub",
  ember: "Ember",
  eia: "EIA",
  ppac: "PPAC",
  tradestat: "TradeStat / DGCI&S",
  "india-energy-derived": "PPAC + TradeStat / DGCI&S",
  "un-comtrade": "UN Comtrade",
  owid: "Our World in Data",
  waqi: "WAQI",
  "open-meteo": "Open-Meteo",
  "world-context": "World Bank + Our World in Data",
  trai: "TRAI",
  "rbi-sibc": "RBI",
  ceew: "CEEW",
  imd: "IMD",
  nfhs: "NFHS",
  mospi: "MoSPI",
  hces: "MoSPI HCES",
  "lancet-countdown": "Lancet Countdown",
  "heat-vulnerability": "CEEW + MoSPI + NITI + HCES + MCCD",
  "heat-work": "MoSPI + ILOSTAT",
  era5: "Copernicus ERA5"
};

function fmt(value: number, unit = "") {
  const abs = Math.abs(value);
  if (/multiple/i.test(unit)) return `${value.toLocaleString("en-IN", { maximumFractionDigits: 1 })}x`;
  if (/crore/i.test(unit) && /inr|₹|rs/i.test(unit)) {
    if (abs >= 100_000) return `₹${(value / 100_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} lakh cr`;
    if (abs >= 1_000) return `₹${(value / 1_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}k cr`;
    return `₹${value.toLocaleString("en-IN", { maximumFractionDigits: 0 })} cr`;
  }
  if (/rupees|inr|₹/i.test(unit)) {
    if (abs >= 1_000_000_000_000) return `₹${(value / 1_000_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} lakh cr`;
    if (abs >= 10_000_000_000) return `₹${(value / 10_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}k cr`;
    if (abs >= 10_000_000) return `₹${(value / 10_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} cr`;
    if (abs >= 100_000) return `₹${(value / 100_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} lakh`;
    if (abs >= 1000) return `₹${value.toLocaleString("en-IN", { maximumFractionDigits: 0 })}`;
  }
  if (/US\$|usd|\$/i.test(unit)) {
    if (abs >= 1_000_000_000_000) return `$${(value / 1_000_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 2 })}T`;
    if (abs >= 1_000_000_000) return `$${(value / 1_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}B`;
  }
  if (/people/i.test(unit) && abs >= 10_000_000) return `${(value / 10_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} cr`;
  if (abs >= 1_000_000_000) return `${(value / 1_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}B`;
  if (abs >= 1_000_000) return `${(value / 1_000_000).toFixed(1)}M`;
  if (abs >= 1000) return `${(value / 1000).toFixed(1)}k`;
  if (abs >= 100) return value.toFixed(0);
  return value.toFixed(1);
}

function compactBarLabel(value: number, unit = "") {
  const abs = Math.abs(value);
  if (/multiple/i.test(unit)) return `${value.toLocaleString("en-IN", { maximumFractionDigits: 1 })}x`;
  if (/crore/i.test(unit) && /inr|₹|rs/i.test(unit)) {
    if (abs >= 100_000) return `₹${(value / 100_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}L cr`;
    if (abs >= 1_000) return `₹${(value / 1_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}k cr`;
    return `₹${value.toLocaleString("en-IN", { maximumFractionDigits: 0 })} cr`;
  }
  if (/rupees|inr|₹/i.test(unit)) {
    if (abs >= 1_000_000_000_000) return `₹${(value / 1_000_000_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })}L cr`;
    if (abs >= 10_000_000) return `₹${(value / 10_000_000).toLocaleString("en-IN", { maximumFractionDigits: 1 })} cr`;
  }
  return fmt(value, unit);
}

function shortLabel(label: string) {
  const dimensions = label.match(/\(([^)]+)\)/)?.[1]
    .split(",")
    .map((item) => item.trim())
    .filter((item) => item && !/not applicable/i.test(item));
  const cleaned = label
    .replace(/: value$/i, "")
    .replace(/: NumericValue$/i, "")
    .replace(/ by sex/i, "")
    .replace(/\s+\([^)]*\)/g, "")
    .replace(/, latest/i, "")
    .replace(/, earliest/i, "");
  return dimensions?.length ? `${cleaned} · ${dimensions.join(" · ")}` : cleaned;
}

function kpiLabel(item: LockedNumber) {
  const raw = item.label.toLowerCase();
  const dims = item.label.match(/\(([^)]+)\)/)?.[1]
    .split(",")
    .map((part) => part.trim())
    .filter((part) => part && !/not applicable/i.test(part)) || [];
  const sex = dims.find((part) => /both sexes|male|female/i.test(part));
  const variant = dims.find((part) => /median|high|low|constant|zero/i.test(part));
  if (raw.includes("population")) {
    if (/high/i.test(variant || "")) return "High-fertility scenario";
    if (/low/i.test(variant || "")) return "Low-fertility scenario";
    if (/male/i.test(sex || "") && !/female/i.test(sex || "")) return "Men";
    if (/female/i.test(sex || "")) return "Women";
    if (/latest/i.test(raw)) return "Latest population estimate";
    if (/earliest/i.test(raw)) return "Earliest population estimate";
    return "Projected population";
  }
  if (/latest/i.test(raw)) return `Latest ${shortLabel(item.label).toLowerCase()}`;
  if (/earliest/i.test(raw)) return `Earliest ${shortLabel(item.label).toLowerCase()}`;
  return shortLabel(item.label);
}

function kpisToShow(items: LockedNumber[]) {
  const preferred = [
    "econ.idh.nominal_gdp_annual",
    "econ.idh.per_capita_nominal_gdp",
    "econ.idh.real_gdp_annual",
    "econ.idh.gva_services_nominal",
    "econ.idh.private_consumption_nominal"
  ];
  const latest = items.filter((item) => /latest/i.test(item.label));
  const pool = latest.length ? latest : items;
  const seen = new Set<string>();
  return [...pool]
    .sort((a, b) => {
      const ai = preferred.indexOf(a.indicatorId);
      const bi = preferred.indexOf(b.indicatorId);
      if (ai !== -1 || bi !== -1) return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
      return 0;
    })
    .filter((item) => {
      if (seen.has(item.indicatorId)) return false;
      seen.add(item.indicatorId);
      return true;
    })
    .slice(0, 5);
}

function valueParts(item: LockedNumber) {
  const formatted = formatLockedNumber(item);
  const value = /rupees|inr|₹/i.test(item.unit) && !formatted.includes("₹") ? fmt(item.value, item.unit) : formatted;
  const match = value.match(/^(.+?)\s+(crore|lakh|million|billion|trillion)$/i);
  if (!match) return { number: value, unit: "" };
  return { number: match[1], unit: match[2] };
}

function kpiValue(item: LockedNumber) {
  return fmt(item.value, item.unit);
}

function pct(value: number | null) {
  if (value === null || !Number.isFinite(value)) return "n/a";
  const sign = value > 0 ? "+" : "";
  return `${sign}${value.toLocaleString("en-IN", { maximumFractionDigits: 1 })}%`;
}

function signedFmt(value: number, unit = "") {
  const sign = value > 0 ? "+" : value < 0 ? "-" : "";
  return `${sign}${fmt(Math.abs(value), unit)}`;
}

function yearSpan(start: string, end: string) {
  const startYear = Number(start);
  const endYear = Number(end);
  if (!Number.isFinite(startYear) || !Number.isFinite(endYear)) return null;
  const span = endYear - startYear;
  return span > 0 ? span : null;
}

function multiple(start: number, end: number) {
  if (!start || !Number.isFinite(start) || !Number.isFinite(end)) return "n/a";
  return `${(end / start).toLocaleString("en-IN", { maximumFractionDigits: 2 })}x`;
}

function formatAxisLabel(date: string) {
  const match = String(date).match(/^(\d{4})(?:-(\d{2})-\d{2})?/);
  if (!match) return date;
  return match[1];
}

function svgCoord(value: number, precision = 1) {
  return Number(value.toFixed(precision)).toString();
}

function cardClass(visualIndex: number, visual: VisualSpec, leadFirst = true) {
  // Explicit plan size wins over heuristics: hero = full+large, feature = full, small = grid cell.
  const size = (visual as { size?: string }).size;
  if (size === "hero") return "viz-card viz-main";
  if (size === "feature") return "viz-card viz-wide";
  if (size === "small") return "viz-card";
  if (leadFirst && visualIndex === 0) return "viz-card viz-main";
  if (visual.kind === "change") return "viz-card viz-wide";
  if (visual.kind === "line" && visual.lines.length > 1) return "viz-card viz-wide";
  if (visual.kind === "linePanels") return "viz-card viz-wide";
  if (visual.kind === "groupedBar") return "viz-card viz-wide";
  if (visual.kind === "bar" && visual.title.toLowerCase().includes("trade flows")) return "viz-card viz-wide";
  if (visual.kind === "bar" && visual.title.toLowerCase().includes("change by decade")) return "viz-card viz-wide";
  if (visual.kind === "bar" && visual.bars.length > 8) return "viz-card viz-wide";
  if (visual.kind === "pyramid" || visual.kind === "stack") return "viz-card viz-wide";
  if (visual.kind === "stripes") return "viz-card viz-wide";
  if (visual.kind === "choropleth" || visual.kind === "scatter" || visual.kind === "scenarioMaps" || visual.kind === "sparkGrid" || visual.kind === "rankedChange") return "viz-card viz-wide";
  return "viz-card";
}

function sourceName(sourceId: string) {
  return sourceNames[sourceId] || sourceId;
}

function sourceLabel(source: VisualSpec["source"]) {
  const id = String(source.sourceIndicatorId || "");
  if (source.sourceId === "ppac") {
    if (id === "international-prices-crude-oil.indian-basket.$-per-bbl") return "PPAC · Indian crude basket price · $/bbl";
    if (id.startsWith("import-export:2025-2026:reportBy:1")) return "PPAC · Import/export of crude oil and petroleum products, quantity · 2025-26";
    if (id.startsWith("import-export:2025-2026:reportBy:2")) return "PPAC · Import/export of crude oil and petroleum products, value in rupees · 2025-26";
    if (id.startsWith("import-export:2025-2026:reportBy:3")) return "PPAC · Import/export of crude oil and petroleum products, value in dollars · 2025-26";
    if (id.includes("NG-C-LNG-Import")) return "PPAC · LNG imports, quantity and value · 2025-26";
    return `PPAC · ${id}`;
  }
  if (source.sourceId === "tradestat") {
    const history = id.match(/^(\d+)\.imports\.partner-history\.(\d{4})-(\d{4})$/);
    if (history) return `TradeStat / DGCI&S · HS ${history[1]} imports by partner · ${history[2]}-${String(Number(history[2]) + 1).slice(-2)} to ${history[3]}-${String(Number(history[3]) + 1).slice(-2)}`;
    const hs = id.match(/^(\d+)\.imports\.(\d{4})$/);
    if (hs) return `TradeStat / DGCI&S · HS ${hs[1]} imports by partner · ${hs[2]}-${String(Number(hs[2]) + 1).slice(-2)}`;
    return `TradeStat / DGCI&S · ${id}`;
  }
  if (source.sourceId === "ember") {
    if (id === "electricity-generation/yearly") return "Ember · Yearly electricity generation by source";
    if (id === "electricity-demand/yearly") return "Ember · Yearly electricity demand";
    if (id === "carbon-intensity/yearly") return "Ember · Yearly electricity carbon intensity";
  }
  if (source.sourceId === "worldbank") {
    if (id === "EG.ELC.ACCS.ZS") return "World Bank · Access to electricity (% of population)";
    if (id === "SP.POP.TOTL") return "World Bank · Population, total";
  }
  if (source.sourceId === "india-energy-derived") {
    if (id === "ppac-and-tradestat.fuel-import-spend.2025-2026") return "PPAC + TradeStat / DGCI&S · Fuel import spend · 2025-26";
  }
  return `${sourceName(source.sourceId)} · ${id}`;
}

function cleanSubtitle(value: string, sourceId: string) {
  return value
    .replace(sourceId, sourceName(sourceId))
    .replace(" · value", "")
    .replace(" · NumericValue", "");
}

function insightForVisual(visual: VisualSpec) {
  const title = visual.title.toLowerCase();
  if (title.includes("latest gva by sector")) return "This is the production-side split. It shows whether the economy is mainly agriculture, industry, or services at the latest point.";
  if (title.includes("what gdp is made of")) return "This is the spending-side split. Household consumption, investment, government consumption, and net exports are different ways GDP gets counted.";
  if (title.includes("trade flows") || title.includes("imports and exports")) return "Each year has two bars: exports and imports. When the import bar is taller, net exports are negative and subtract from GDP.";
  if (title.includes("nominal gdp")) return "This is the headline size of the economy in current rupees. It includes both real growth and price changes, so read it as the money value of output.";
  if (title.includes("real gdp")) return "This removes the effect of inflation using 2011-12 prices. Use it when the question is growth in actual output, not just bigger rupee numbers.";
  if (title.includes("per capita")) return "This divides the economy by the population. It is closer to the average-person question than total GDP, but it still says nothing about distribution.";
  if (title.includes("gva") && title.includes("agriculture")) return "Agriculture supports a large share of livelihoods, but its output share is much smaller than services or industry. That gap is the structural story.";
  if (title.includes("gva") && title.includes("industry")) return "Industry is the production base: factories, construction, mining, utilities. Watch whether it is expanding fast enough to absorb workers productively.";
  if (title.includes("gva") && title.includes("services")) return "Services are the largest block of the economy. A services-heavy economy can grow fast, but the jobs question has to be asked separately.";
  if (title.includes("private final consumption")) return "This is household spending. If this line is large, the economy is being pulled heavily by what people buy.";
  if (title.includes("gross capital formation")) return "This is the investment line: buildings, machines, infrastructure, and inventories. It matters because today's investment shapes tomorrow's capacity.";
  if (title.includes("government final consumption")) return "This is government spending on current services, not all public investment. It is one part of the state footprint in GDP.";
  if (title.includes("net exports")) return "Positive means exports exceed imports. Negative means imports are larger, so domestic demand is partly being met from abroad.";
  if (title.includes("population, total")) return "Read the headline chart as the scale of the whole country. Every later percentage on this page sits on top of this denominator.";
  if (title.includes("scenario spread")) return "The variants are close, but the gap still represents crores of people. Projection uncertainty is small as a percentage and large in human terms.";
  if (title.includes("crude rate")) return "The slope is the key: India is still growing, but the annual pace of addition is slowing.";
  if (title.includes("median age")) return "Median age moves slowly, which is why this rising line matters. It shows the population becoming older even while India remains young overall.";
  if (title.includes("broad age")) return "This is the quick dependency picture: children, working-age people, and older adults as shares of the total.";
  if (title.includes("pyramid")) return "The widest bands show where demographic pressure sits today. A rectangular shape would mean an older, slower-growing population.";
  if (title.includes("5-year age")) return "This is the granular version of the age story. It shows which cohorts are largest instead of compressing everyone into three buckets.";
  if (title.includes("by sex")) return "The male and female lines move together, but their gap is visible. Use this with the pyramid for the age-specific picture.";
  if (title.includes("change by decade")) return "This breaks the big rise into periods, so the reader can see when the population added more or less in absolute terms.";
  if (title.includes("how much changed")) return "Read this as the extra population added, not the latest population repeated. The decade chart above shows how that addition was distributed over time.";
  return "Use this chart as one view of the evidence, then read it beside the neighbouring charts before drawing a conclusion.";
}

function indicatorIdForVisual(visual: VisualSpec) {
  return visual.source.indicatorId || "";
}

function slugifyTitle(value: string) {
  return String(value).toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

function explainerForVisual(visual: VisualSpec, index: number) {
  const indicatorId = indicatorIdForVisual(visual);
  const title = visual.title.toLowerCase();
  const slug = slugifyTitle(visual.title);
  const generated = chartExplainers.find((item) =>
    slugifyTitle(item.visualId || "") === slug ||
    (indicatorId && item.visualId?.endsWith(indicatorId)) ||
    item.title?.toLowerCase() === visual.title.toLowerCase() ||
    (item.title && item.title.toLowerCase().includes(visual.title.toLowerCase()))
  );
  if (!generated && title.includes("latest gva by sector")) {
    return {
      index: index + 1,
      title: visual.title,
      whyShowThis: "Total GDP answers the size question. The sector chart answers the next question: what kind of economy creates that output.",
      howToRead: insightForVisual(visual),
      mistakeToAvoid: "Do not read sector output as sector employment. Agriculture can support many workers while forming a smaller share of output.",
      mobileNote: "Use three horizontal bars and short labels."
    };
  }
  if (!generated && title.includes("what gdp is made of")) {
    return {
      index: index + 1,
      title: visual.title,
      whyShowThis: "GDP is not just one giant number. This chart shows the spending pieces behind it.",
      howToRead: insightForVisual(visual),
      mistakeToAvoid: "Do not add this up like a household budget. Net exports can be negative because imports are subtracted in GDP accounting.",
      mobileNote: "Keep the zero line visible because net exports can go below zero."
    };
  }
  if (!generated && title.includes("quarterly")) {
    return {
      index: index + 1,
      title: visual.title,
      whyShowThis: title.includes("nominal")
        ? "The annual number gives scale. The quarterly nominal line shows the latest current-price size within the year."
        : "The annual number gives scale. The quarterly real line shows the more recent movement in inflation-adjusted output.",
      howToRead: insightForVisual(visual),
      mistakeToAvoid: "Do not compare one quarter directly with a full financial year. The units are rupees, but the time periods are different.",
      mobileNote: "Use sparse year ticks and a clear latest-point label."
    };
  }
  if (!generated && (title.includes("trade flows") || title.includes("imports and exports"))) {
    return {
      index: index + 1,
      title: visual.title,
      whyShowThis: "Net exports alone is too compressed. This chart shows the two large flows behind it: what India sells abroad and what it buys from abroad.",
      howToRead: insightForVisual(visual),
      mistakeToAvoid: "Do not read a trade deficit as exports being unimportant. It means imports are larger than exports in value.",
      mobileNote: "Use horizontal bars with a visible zero line for the net export bar."
    };
  }
  // Curated plan note (from the registry visualPlan) is the fallback before the
  // generic boilerplate, so every chart gets a specific reason even before the
  // LLM-generated chartExplainers exist.
  const note = (visual as { note?: { why?: string; detail?: string; read?: string; watch?: string } }).note;
  return {
    index: index + 1,
    title: generated?.title || visual.title,
    // takeaway = the one-line point; detail = a fuller plain-language paragraph.
    takeaway: generated?.takeaway || note?.why || generated?.whyShowThis || "What this chart is telling you.",
    detail: note?.detail || generated?.detail || generated?.whyShowThis || note?.read || insightForVisual(visual),
    howToRead: generated?.howToRead || note?.read || insightForVisual(visual),
    mistakeToAvoid: generated?.mistakeToAvoid || note?.watch || "Do not turn one line into the whole story. Check the unit, the source, and the companion charts.",
    mobileNote: generated?.mobileNote || "Keep the chart simple on phones: fewer ticks, short labels, and one clear takeaway."
  };
}

const chartDownloadBase = `${Astro.url.pathname.replace(/\/$/, "")}/charts`;

// Cool->hot "temperature" ramp (blue -> marigold -> coral) for severity-graded bars.
function tempColor(t: number) {
  t = Math.max(0, Math.min(1, t));
  const stops: Array<[number, number, number, number]> = [[0, 108, 143, 214], [0.5, 239, 162, 39], [1, 232, 96, 76]];
  let a = stops[0], b = stops[stops.length - 1];
  for (let i = 0; i < stops.length - 1; i++) { if (t >= stops[i][0] && t <= stops[i + 1][0]) { a = stops[i]; b = stops[i + 1]; break; } }
  const f = b[0] > a[0] ? (t - a[0]) / (b[0] - a[0]) : 0;
  return `rgb(${Math.round(a[1] + (b[1] - a[1]) * f)},${Math.round(a[2] + (b[2] - a[2]) * f)},${Math.round(a[3] + (b[3] - a[3]) * f)})`;
}

// Diverging blue->white->red colour for a value relative to a centre and spread.
function stripeColor(value: number, center: number, spread: number) {
  const t = Math.max(-1, Math.min(1, spread > 0 ? (value - center) / spread : 0));
  if (t >= 0) {
    // white -> red
    const r = 200, g = Math.round(200 - 168 * t), b = Math.round(200 - 168 * t);
    return `rgb(${r},${Math.max(28, g)},${Math.max(36, b)})`;
  }
  // white -> blue
  const a = -t;
  return `rgb(${Math.round(200 - 150 * a)},${Math.round(200 - 70 * a)},${Math.round(200 + 40 * a)})`;
}

// Round axis bounds and ticks to "nice" values (1/2/5 x 10^n), the d3-style algorithm,
// so a chart reads 0 / 1B / 2B / 3B instead of 0 / 835.1M / 1.7B / 2.5B.
function niceNum(range: number, round: boolean) {
  if (!(range > 0) || !Number.isFinite(range)) return 1;
  const exp = Math.floor(Math.log10(range));
  const frac = range / Math.pow(10, exp);
  const nf = round
    ? (frac < 1.5 ? 1 : frac < 3 ? 2 : frac < 7 ? 5 : 10)
    : (frac <= 1 ? 1 : frac <= 2 ? 2 : frac <= 5 ? 5 : 10);
  return nf * Math.pow(10, exp);
}
function niceScale(lo: number, hi: number, count = 5) {
  if (!(hi > lo)) hi = lo + 1;
  const step = niceNum(niceNum(hi - lo, false) / Math.max(1, count - 1), true);
  const niceMin = Math.floor(lo / step) * step;
  const niceMax = Math.ceil(hi / step) * step;
  const ticks: number[] = [];
  for (let v = niceMin; v <= niceMax + step * 0.5; v += step) ticks.push(Number(v.toPrecision(12)));
  return { min: niceMin, max: niceMax, ticks };
}

function lineGeometry(visual: LineVisual, isLead = false, twoUp = false, bounds?: { min?: number; max?: number }) {
  // The viewBox width is matched to how wide the chart actually renders, so one fixed
  // axis-font size reads consistently: 2-up (leftover grid) charts render ~half width
  // and use a narrow box; section-bound charts render full width and use a wide box.
  // Without this, the same font is tiny on half-width charts and garish on full-width ones.
  const width = twoUp ? (isLead ? 720 : 660) : (isLead ? 1120 : 1000);
  const isHero = (visual as { size?: string }).size === "hero";
  const height = isHero ? 560 : isLead ? 500 : 360;
  const pad = isLead ? { l: 86, r: visual.lines.length > 1 ? 156 : 88, t: 38, b: 58 } : { l: 58, r: visual.lines.length > 1 ? 118 : 48, t: 28, b: 44 };
  const all = visual.lines.flatMap((line) => line.points);
  const values = all.map((point) => point.value);
  const useLogScale = visual.title.toLowerCase().includes("gdp per person over time");
  const positiveValues = values.filter((value) => value > 0);
  const rawMin = Math.min(...values);
  const rawMax = Math.max(...values);
  const bounded = bounds && (typeof bounds.min === "number" || typeof bounds.max === "number");
  const scaleMin = typeof bounds?.min === "number" ? bounds.min : rawMin;
  const scaleMax = typeof bounds?.max === "number" ? bounds.max : rawMax;
  const logMinRaw = Math.max(1, (Math.min(...positiveValues) || 1) * 0.8);
  const logMaxRaw = Math.max(10, (Math.max(...positiveValues) || 10) * 1.18);
  // Temperature/ratio-like data (range small next to its own values) is not zero-baselined,
  // or the lines compress into a thin band; magnitude data (range >> min, e.g. emissions,
  // population) keeps a 0 floor so area height stays meaningful.
  const tight = !bounded && rawMin > 0 && (rawMax - rawMin) < rawMin;
  const linear = niceScale(scaleMin < 0 ? scaleMin : tight ? scaleMin : 0, scaleMax || 1, 5);
  const min = useLogScale ? Math.log10(logMinRaw) : linear.min;
  const max = useLogScale ? Math.log10(logMaxRaw) : linear.max;
  const span = max - min || 1;
  const plotW = width - pad.l - pad.r;
  // Position points by real time. Monthly series must use the month too; otherwise all
  // twelve YYYY-MM points in a year collapse onto one x-position and render as steps.
  const timeOf = (d: string) => {
    const m = String(d).match(/^(-?\d{3,4})(?:-(\d{2}))?/);
    if (!m) return null;
    const year = Number(m[1]);
    const month = m[2] ? Number(m[2]) : 1;
    return year + (Math.max(1, Math.min(12, month)) - 1) / 12;
  };
  const totalPoints = visual.lines.reduce((n, l) => n + l.points.length, 0);
  const timesAll = visual.lines.flatMap((line) => line.points.map((p) => timeOf(p.date))).filter((v): v is number => v !== null);
  const dateMode = timesAll.length === totalPoints && timesAll.length > 0 && Math.max(...timesAll) > Math.min(...timesAll);
  const minTime = dateMode ? Math.min(...timesAll) : 0;
  const maxTime = dateMode ? Math.max(...timesAll) : 1;
  const xByTime = (time: number) => pad.l + ((time - minTime) / Math.max(1 / 12, maxTime - minTime)) * plotW;
  const xByIndex = (index: number, count: number) => pad.l + (index / Math.max(1, count - 1)) * plotW;
  const px = (point: Point, index: number, count: number) => (dateMode ? xByTime(timeOf(point.date) ?? minTime) : xByIndex(index, count));
  const scaled = (value: number) => useLogScale ? Math.log10(Math.max(1, value)) : value;
  const y = (value: number) => height - pad.b - ((scaled(value) - min) / span) * (height - pad.t - pad.b);
  const logTicks = [100, 1000, 10000, 100000].filter((tick) => tick >= logMinRaw * 0.9 && tick <= logMaxRaw * 1.1);
  const ticks = useLogScale && logTicks.length >= 2 ? logTicks : linear.ticks;
  const pathsRaw = visual.lines.map((line, lineIndex) => {
    const d = line.points.map((point, index) => `${index === 0 ? "M" : "L"}${svgCoord(px(point, index, line.points.length))} ${svgCoord(y(point.value))}`).join("");
    const xFirst = px(line.points[0], 0, line.points.length);
    const xLast = px(line.points[line.points.length - 1], line.points.length - 1, line.points.length);
    const areaD = `${d}L${svgCoord(xLast)} ${svgCoord(height - pad.b)}L${svgCoord(xFirst)} ${svgCoord(height - pad.b)}Z`;
    const latest = line.points.at(-1);
    const latestX = latest ? xLast : 0;
    const latestY = latest ? y(latest.value) : 0;
    return { ...line, d, areaD, latest, latestX, latestY, color: colors[lineIndex % colors.length] };
  });
  const minGap = isLead ? 34 : 24;
  const labelTop = pad.t + 14;
  const labelBottom = height - pad.b - 10;
  const sorted = pathsRaw
    .map((path, index) => ({ index, y: path.latestY }))
    .sort((a, b) => a.y - b.y);
  for (let i = 1; i < sorted.length; i += 1) {
    if (sorted[i].y - sorted[i - 1].y < minGap) sorted[i].y = sorted[i - 1].y + minGap;
  }
  const overflow = sorted.at(-1) ? sorted.at(-1)!.y - labelBottom : 0;
  if (overflow > 0) {
    for (const item of sorted) item.y -= overflow;
  }
  for (let i = sorted.length - 2; i >= 0; i -= 1) {
    if (sorted[i + 1].y - sorted[i].y < minGap) sorted[i].y = sorted[i + 1].y - minGap;
  }
  for (const item of sorted) item.y = Math.max(labelTop, Math.min(labelBottom, item.y));
  const labelY = new Map(sorted.map((item) => [item.index, item.y]));
  const paths = pathsRaw.map((path, index) => ({ ...path, labelY: labelY.get(index) || path.latestY }));
  const tickCount = isLead ? 5 : 4;
  let axisTicks: Array<{ xPos: number; label: string }>;
  if (dateMode) {
    axisTicks = niceScale(minTime, maxTime, tickCount).ticks
      .filter((time) => time >= minTime && time <= maxTime)
      .map((time) => ({ xPos: xByTime(time), label: String(Math.round(time)) }));
  } else {
    const ap = visual.lines[0]?.points || [];
    axisTicks = Array.from({ length: tickCount }, (_, i) => Math.round((i / (tickCount - 1)) * Math.max(0, ap.length - 1)))
      .filter((v, i, arr) => arr.indexOf(v) === i)
      .filter((i) => ap[i])
      .map((i) => ({ xPos: xByIndex(i, ap.length), label: formatAxisLabel(ap[i].date) }));
  }
  return { width, height, pad, ticks, paths, axisTicks, y };
}

function groupedBarGeometry(visual: GroupedBarVisual) {
  const width = 1160;
  const height = 430;
  const pad = { l: 86, r: 46, t: 34, b: 70 };
  const values = visual.groups.flatMap((group) => group.values);
  const max = Math.max(...values, 1) * 1.12;
  const plotW = width - pad.l - pad.r;
  const plotH = height - pad.t - pad.b;
  const groupW = plotW / Math.max(1, visual.groups.length);
  const barGap = 5;
  const barW = Math.max(8, Math.min(30, (groupW - 18 - barGap) / Math.max(1, visual.series.length)));
  const y = (value: number) => height - pad.b - (value / max) * plotH;
  const ticks = Array.from({ length: 5 }, (_, index) => (max * index) / 4);
  return { width, height, pad, max, groupW, barGap, barW, y, ticks };
}

function scatterGeometry(visual: ScatterVisual) {
  const width = 1160;
  const height = 520;
  const pad = { l: 94, r: 120, t: 44, b: 86 };
  const plotW = width - pad.l - pad.r;
  const plotH = height - pad.t - pad.b;
  const xSpan = visual.xMax - visual.xMin || 1;
  const ySpan = visual.yMax - visual.yMin || 1;
  const x = (value: number) => pad.l + ((value - visual.xMin) / xSpan) * plotW;
  const y = (value: number) => height - pad.b - ((value - visual.yMin) / ySpan) * plotH;
  const sizes = visual.points.map((point) => point.size || 0).filter((value) => value > 0);
  const maxSize = Math.max(...sizes, 1);
  const r = (value?: number | null) => 5 + Math.sqrt(Math.max(0, value || 0) / maxSize) * 17;
  const ticks = [0, 25, 50, 75, 100];
  const labelExcluded = new Set([
    "Andaman and Nicobar Islands",
    "Chandigarh",
    "Dadra and Nagar Haveli and Daman and Diu"
  ]);
  const labelledPoints = [...visual.points]
    .filter((point) => !labelExcluded.has(point.label))
    .sort((a, b) => (b.x * b.y * (b.size || 1)) - (a.x * a.y * (a.size || 1)))
    .slice(0, 5);
  const labelled = new Set(labelledPoints.map((point) => point.label));
  const rawLabels = labelledPoints.map((point) => {
    const cx = x(point.x);
    const cy = y(point.y);
    const radius = r(point.size);
    const side = point.x >= 70 ? "left" : "right";
    const textX = side === "left" ? cx - radius - 24 : cx + radius + 24;
    return {
      label: point.label,
      text: point.label,
      side,
      x: textX,
      y: cy - radius - 5,
      lineX1: side === "left" ? cx - radius * 0.65 : cx + radius * 0.65,
      lineY1: cy - radius * 0.65,
      lineX2: side === "left" ? textX + 5 : textX - 5
    };
  });
  const labelsBySide = ["left", "right"].flatMap((side) => {
    const items = rawLabels.filter((item) => item.side === side).sort((a, b) => a.y - b.y);
    const minGap = 34;
    const top = pad.t + 16;
    const bottom = height - pad.b - 12;
    for (let i = 1; i < items.length; i += 1) {
      if (items[i].y - items[i - 1].y < minGap) items[i].y = items[i - 1].y + minGap;
    }
    const overflow = items.at(-1) ? Math.max(0, items.at(-1)!.y - bottom) : 0;
    if (overflow) for (const item of items) item.y -= overflow;
    for (let i = items.length - 2; i >= 0; i -= 1) {
      if (items[i + 1].y - items[i].y < minGap) items[i].y = items[i + 1].y - minGap;
    }
    const underflow = items[0] ? Math.max(0, top - items[0].y) : 0;
    if (underflow) for (const item of items) item.y += underflow;
    return items;
  });
  const labelPositions = new Map(labelsBySide.map((item) => [item.label, item]));
  return { width, height, pad, x, y, r, ticks, labelled, labelPositions };
}

