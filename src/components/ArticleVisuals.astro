              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "stripPair") {
          const sp = visual as StripPairVisual;
          return (
            <article class="viz-card viz-wide">
              <div class="viz-head"><div><h2 class="serif">{sp.title}</h2><p>{cleanSubtitle(sp.subtitle, source.sourceId)}</p></div><span>{sp.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              {sp.rows.map((row) => {
                const tot = row.segments.reduce((s, x) => s + x.value, 0) || 1;
                return (
                  <div class="strip-pair-row">
                    <span class="strip-pair-label">{row.label}</span>
                    <div class="share-strip">
                      {row.segments.map((seg, index) => {
                        const pct = (seg.value / tot) * 100;
                        const showLabel = pct >= 11;
                        const lbl = `${seg.label} · ${Math.round(seg.value)}%`;
                        return (
                          <div style={`width:${pct}%;background:${colors[index % colors.length]}`}>
                            {showLabel ? <span>{lbl}</span> : null}
                          </div>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
              <div class="strip-legend">
                {sp.rows[0].segments.map((seg, index) => (
                  <span class="sl-item"><i style={`background:${colors[index % colors.length]}`}></i>{seg.label}</span>
                ))}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
                <div class="viz-source"><span>Source</span>{source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}</div>
              </div>
            </article>
          );
        }

        if (visual.kind === "stack") {
          const stack = visual as StackVisual;
          const total = stack.segments.reduce((sum, item) => sum + item.value, 0) || 1;
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{stack.title}</h2><p>{cleanSubtitle(stack.subtitle, source.sourceId)}</p></div><span>{stack.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <div class="viz-stack">
                {stack.segments.map((segment, index) => {
                  const segPct = (segment.value / total) * 100;
                  return (
                    <div class="viz-seg" style={`width:${segPct}%;background:${colors[index % colors.length]}`}>
                      {segPct >= 9 ? <span>{segment.label}</span> : null}
                    </div>
                  );
                })}
              </div>
              <div class="viz-bars">
                {stack.segments.map((segment) => (
                  <div class="viz-bar"><span>{segment.label}</span><div><i style={`width:${(segment.value / total) * 100}%`}></i></div><b>{fmt(segment.value, stack.unit)}</b></div>
                ))}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "bar") {
          const bar = visual as BarVisual;
          const max = Math.max(...bar.bars.map((item) => Math.abs(item.value)), 1);
          const isLog = (bar as { scale?: string }).scale === "log";
          const logVals = bar.bars.map((b) => b.value).filter((v) => v > 0);
          const logMin = isLog && logVals.length ? Math.log(Math.min(...logVals)) : 0;
          const logSpan = (isLog && logVals.length ? Math.log(Math.max(...logVals)) : 1) - logMin || 1;
          const logW = (v: number) => v > 0 ? 4 + ((Math.log(v) - logMin) / logSpan) * 95 : 2;
          const logColor = (v: number) => tempColor(v > 0 ? (Math.log(v) - logMin) / logSpan : 0);
          const hasNegative = bar.bars.some((item) => item.value < 0);
          const isComparison = Boolean(source.indicatorId?.startsWith("compare.") || source.indicatorId?.startsWith("econ.compare."));
          // Share-strip only for a few big slices; many small slices (e.g. 6 age
          // groups with a 2% tail) render far more legibly as horizontal bars.
          const isStrip = (bar as { share?: boolean }).share === true;
          const isShare = isStrip || (/%/.test(bar.unit) && bar.bars.length <= 4 && !hasNegative && !isComparison);
          const total = bar.bars.reduce((sum, item) => sum + Math.max(0, item.value), 0) || 1;
          const groupedBars = [...new Set(bar.bars.map((item) => item.group).filter(Boolean))] as string[];
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{bar.title}</h2><p>{cleanSubtitle(bar.subtitle, source.sourceId)}</p></div><span>{bar.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              {isShare ? (
                <div class="share-strip">
                  {bar.bars.map((item, index) => {
                    const pct = (item.value / total) * 100;
                    const showLabel = pct >= 11;
                    const lbl = isStrip ? `${item.label} · ${Math.round(item.value)}%` : item.label;
                    return (
                    <div style={`width:${pct}%;background:${colors[index % colors.length]}`}>
                      {showLabel ? <span>{lbl}</span> : null}
                    </div>
                    );
                  })}
                </div>
              ) : null}
              {isStrip ? (
                <div class="strip-legend">
                  {bar.bars.map((item, index) => (
                    <span class="sl-item"><i style={`background:${colors[index % colors.length]}`}></i>{item.label} · {Math.round(item.value)}%</span>
                  ))}
                </div>
              ) : null}
              {!isStrip && groupedBars.length ? (
              <div class="viz-bar-groups">
                {groupedBars.map((group) => {
                  const items = bar.bars.filter((item) => item.group === group);
                  const groupMax = Math.max(100, ...items.map((item) => Math.abs(item.value)));
                  return (
                    <div class="viz-bar-group">
                      <h3>{group}</h3>
                      <div class="viz-bars">
                        {items.map((item) => (
                          <div class="viz-bar">
                            <span>{item.label}</span>
                            <div class="viz-bar-track">
                              <i style={`width:${(item.value / groupMax) * 100}%`}></i>
                            </div>
                            <b>{fmt(item.value, bar.unit)}</b>
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
              ) : !isStrip ? (
              <div class="viz-bars">
                {bar.bars.map((item) => (
                  <div class="viz-bar">
                    <span>{item.label}</span>
                    <div class={hasNegative ? "viz-bar-track bipolar" : "viz-bar-track"}>
                      <i class={item.value < 0 ? "neg" : ""} style={hasNegative
                        ? `width:${Math.max(2, (Math.abs(item.value) / max) * 50)}%;margin-left:${item.value < 0 ? 50 - (Math.abs(item.value) / max) * 50 : 50}%;`
                        : isLog
                        ? `width:${logW(item.value)}%;background:${logColor(item.value)}`
                        : `width:${isShare ? item.value : (item.value / max) * 100}%`}
                      ></i>
                    </div>
                    <b>{fmt(item.value, bar.unit)}</b>
                  </div>
                ))}
              </div>
              ) : null}
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "groupedBar") {
          const grouped = visual as GroupedBarVisual;
          const g = groupedBarGeometry(grouped);
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{grouped.title}</h2><p>{cleanSubtitle(grouped.subtitle, source.sourceId)}</p></div><span>{grouped.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <svg class="viz-svg grouped-bars" viewBox={`0 0 ${g.width} ${g.height}`} role="img" aria-label={grouped.title}>
                {g.ticks.map((tick) => (
                  <g>
                    <line x1={g.pad.l} y1={g.y(tick)} x2={g.width - g.pad.r} y2={g.y(tick)} stroke="#ededed" />
                    <text class="yaxt" x={g.pad.l - 12} y={g.y(tick) + 4} text-anchor="end">{fmt(tick, grouped.unit)}</text>
                  </g>
                ))}
                {grouped.groups.map((group, groupIndex) => {
                  const groupX = g.pad.l + groupIndex * g.groupW;
                  const centerX = groupX + g.groupW / 2;
                  const barsW = grouped.series.length * g.barW + (grouped.series.length - 1) * g.barGap;
                  const startX = centerX - barsW / 2;
                  return (
                    <g>
                      {group.values.map((value, valueIndex) => {
                        const x = startX + valueIndex * (g.barW + g.barGap);
                        const y = g.y(value);
                        const h = g.height - g.pad.b - y;
                        const labelX = x + g.barW / 2;
                        const labelY = g.height - g.pad.b - 10;
                        return (
                          <>
                            <rect x={x} y={y} width={g.barW} height={Math.max(1, h)} fill={colors[valueIndex % colors.length]} />
                            {h > 58 ? (
                              <text
                                class="bar-value-label"
                                x={labelX}
                                y={labelY}
                                text-anchor="start"
                                transform={`rotate(-90 ${labelX} ${labelY})`}
                              >
                                {compactBarLabel(value, grouped.unit)}
                              </text>
                            ) : null}
                          </>
                        );
                      })}
                      <text class="xaxt" x={centerX} y={g.height - g.pad.b + 24} text-anchor="middle">{group.label}</text>
                    </g>
                  );
                })}
              </svg>
              <div class="viz-legend">
                {grouped.series.map((name, index) => <span><i style={`background:${colors[index % colors.length]}`}></i>{name}</span>)}
              </div>
              <div class="trade-note-row">
                {grouped.groups.slice(-3).map((group) => (
                  <span><b>{group.label}</b>{typeof group.net === "number" ? signedFmt(group.net, grouped.unit) : "n/a"} net exports</span>
                ))}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "change") {
          const change = visual as ChangeVisual;
          const max = Math.max(...change.items.map((item) => Math.abs(item.change)), 1);
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head">
                <div><h2 class="serif">{change.title}</h2><p>{cleanSubtitle(change.subtitle, source.sourceId)}</p></div>
                <span>{change.unit}</span>
              </div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <div class="change-grid">
                {change.items.slice(0, 4).map((item, index) => (
                  <div class="change-row">
                    <div class="change-main">
                      <span>{shortLabel(item.label)}</span>
                      <b>{signedFmt(item.change, change.unit)}</b>
                      <small>Added from {item.start.date} to {item.end.date}</small>
                    </div>
                    <div class="change-track" aria-label={`${shortLabel(item.label)} changed by ${signedFmt(item.change, change.unit)}`}>
                      <i style={`width:${Math.max(5, (Math.abs(item.change) / max) * 100)}%;background:${colors[index % colors.length]}`}></i>
                    </div>
                    <div class="change-facts">
                      <span><b>{pct(item.pctChange)}</b><small>Total growth</small></span>
                      <span><b>{multiple(item.start.value, item.end.value)}</b><small>End vs start</small></span>
                      {yearSpan(item.start.date, item.end.date) ? (
                        <span><b>{signedFmt(item.change / (yearSpan(item.start.date, item.end.date) || 1), change.unit)}</b><small>Per year avg</small></span>
                      ) : null}
                    </div>
                  </div>
                ))}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "stripes") {
          const stripes = visual as StripeVisual;
          const spread = Math.max(Math.abs(stripes.max - stripes.center), Math.abs(stripes.center - stripes.min)) || 1;
          const n = stripes.stripes.length;
          const w = 1160, h = 200;
          const bw = w / n;
          const first = stripes.stripes[0];
          const last = stripes.stripes[n - 1];
          // Year ticks as real HTML below the band (SVG text would be downscaled to ~8px
          // because the 1160-wide viewBox renders at roughly half that). Force-include the
          // last year so the axis ends on the latest point, not a sampled gap.
          const step = Math.max(1, Math.round((n - 1) / 7));
          const tickIdx: number[] = [];
          for (let i = 0; i < n; i += step) tickIdx.push(i);
          // End cleanly on the latest year: replace a near-final tick rather than crowd it.
          const lastTick = tickIdx[tickIdx.length - 1];
          if (lastTick !== n - 1) {
            if (n - 1 - lastTick < step / 2) tickIdx[tickIdx.length - 1] = n - 1;
            else tickIdx.push(n - 1);
          }
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{stripes.title}</h2><p>{cleanSubtitle(stripes.subtitle, source.sourceId)}</p></div><span>{stripes.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="svg">SVG</button>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <svg class="viz-svg viz-stripes" viewBox={`0 0 ${w} ${h}`} role="img" aria-label={stripes.title} preserveAspectRatio="none">
                {stripes.stripes.map((s, i) => (
                  <rect x={i * bw} y={0} width={bw + 0.6} height={h} fill={stripeColor(s.value, stripes.center, spread)} />
                ))}
              </svg>
              <div class="stripe-axis">
                {tickIdx.map((i) => <span>{formatAxisLabel(stripes.stripes[i].date)}</span>)}
              </div>
              <div class="viz-legend">
                <span><i style={`background:${stripeColor(stripes.min, stripes.center, spread)}`}></i>Cooler ({fmt(stripes.min, stripes.unit)})</span>
                <span><i style={`background:${stripeColor(stripes.max, stripes.center, spread)}`}></i>Hotter ({fmt(stripes.max, stripes.unit)})</span>
                <span><b>{first.date}</b> → <b>{last.date}</b></span>
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "sparkGrid") {
          const sg = visual as SparkGridVisual;
          const usuffix = /%/.test(sg.unit) ? "%" : "";
          const sparkPts = (pts) => {
            const n = pts.length;
            return pts.map((p, i) => `${(n < 2 ? 0 : (i / (n - 1)) * 100).toFixed(1)},${(34 - (sg.max > 0 ? (p.value / sg.max) * 32 : 0)).toFixed(1)}`).join(" ");
          };
          const sparkArea = (pts) => `${sparkPts(pts)} 100,36 0,36`;
          const startYear = sg.cells[0]?.points?.[0]?.date ?? "";
          const endYear = sg.cells[0]?.points?.[sg.cells[0].points.length - 1]?.date ?? "";
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{sg.title}</h2><p>{cleanSubtitle(sg.subtitle, source.sourceId)}</p></div><span>{sg.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <p class="spark-scale">Each chart is one city, {startYear}–{endYear}, all on the same scale: bottom = 0, top = {fmt(sg.max, sg.unit)}{usuffix} {sg.unit}. The big number is the {endYear} value.</p>
              <div class="spark-grid">
                {sg.cells.map((c) => {
                  const col = choroColor(c.latest ?? 0, sg.min, sg.max);
                  return (
                    <div class="spark-cell">
                      <div class="spark-head"><b>{c.label}</b><em style={`color:${col}`}>{fmt(c.latest ?? 0, sg.unit)}{usuffix}</em></div>
                      <svg class="spark-svg" viewBox="0 0 100 36" preserveAspectRatio="none" role="img" aria-label={`${c.label}: ${fmt(c.latest ?? 0, sg.unit)} in ${endYear}`}>
                        <line x1="0" y1="34.5" x2="100" y2="34.5" stroke="#e7e1d8" stroke-width="1" vector-effect="non-scaling-stroke" />
                        <polygon points={sparkArea(c.points)} fill={col} fill-opacity="0.14" stroke="none" />
                        <polyline points={sparkPts(c.points)} fill="none" stroke={col} stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" />
                      </svg>
                      <div class="spark-axis"><span>{startYear}</span><span>{endYear}</span></div>
                    </div>
                  );
                })}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "rankedChange") {
          const rc = visual as RankedChangeVisual;
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{rc.title}</h2><p>{cleanSubtitle(rc.subtitle, source.sourceId)}</p></div><span>{rc.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <div class="ranked-change">
                <div class="ranked-change-head">
                  <span>City</span>
                  <span>{rc.startLabel} avg</span>
                  <span>{rc.endLabel}</span>
                  <span>Change</span>
                </div>
                {rc.rows.map((row) => {
                  const startW = Math.max(1, (row.start / rc.max) * 100);
                  const endW = Math.max(1, (row.end / rc.max) * 100);
                  return (
                    <div class="ranked-change-row">
                      <b>{row.label}</b>
                      <div class="ranked-change-bar muted" aria-label={`${row.label} baseline ${fmt(row.start, rc.unit)}`}>
                        <i style={`width:${startW}%`}></i><span>{fmt(row.start, rc.unit)}</span>
                      </div>
                      <div class="ranked-change-bar hot" aria-label={`${row.label} latest ${fmt(row.end, rc.unit)}`}>
                        <i style={`width:${endW}%`}></i><span>{fmt(row.end, rc.unit)}</span>
                      </div>
                      <em class={row.change >= 0 ? "pos" : "neg"}>{signedFmt(row.change, rc.unit)}</em>
                    </div>
                  );
                })}
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "scenarioMaps") {
          const sm = visual as ScenarioMapsVisual;
          const smGradient = `linear-gradient(90deg, ${choroColor(sm.min, sm.min, sm.max)}, ${choroColor((sm.min + sm.max) / 2, sm.min, sm.max)}, ${choroColor(sm.max, sm.min, sm.max)})`;
          const usuffix = /%/.test(sm.unit) ? "%" : /°C|degree/i.test(sm.unit) ? "°C" : "";
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{sm.title}</h2><p>{cleanSubtitle(sm.subtitle, source.sourceId)}</p></div><span>{sm.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <div class="scenmap-row">
                {sm.panels.map((p) => (
                  <div class="scenmap-cell">
                    <b class="scenmap-label">{p.label}</b>
                    <svg class="viz-svg scenmap-svg" viewBox={sm.viewBox} role="img" aria-label={`${sm.title}: ${p.label}`}>
                      {p.regions.map((r) => (
                        <path d={compactSvgPath(r.path)} fill={r.value === null || r.value === undefined ? "#efeae4" : choroColor(r.value, sm.min, sm.max)} stroke="#fff" stroke-width="0.7" stroke-linejoin="round">
                          <title>{r.name}: {r.value === null || r.value === undefined ? "no data" : `${fmt(r.value, sm.unit)}${usuffix}`}</title>
                        </path>
                      ))}
                    </svg>
                  </div>
                ))}
              </div>
              <div class="scenmap-legend">
                <span class="choro-bar" style={`background:${smGradient}`}></span>
                <span class="choro-ends"><em>{fmt(sm.min, sm.unit)}{usuffix}</em><em>{fmt(sm.max, sm.unit)}{usuffix}</em></span>
                <span class="choro-cap">{sm.unit}</span>
              </div>
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        if (visual.kind === "choropleth") {
          const cho = visual as ChoroplethVisual;
          const valued = cho.regions.filter((r): r is { name: string; value: number; path: string } => r.value !== null && r.value !== undefined);
          const top = [...valued].sort((a, b) => b.value - a.value).slice(0, 3);
          const bottom = cho.bottomLabel ? [...valued].sort((a, b) => a.value - b.value).slice(0, 3) : [];
          const vf = (v: number) => choroplethValueLabel(cho, v);
          const choGradient = `linear-gradient(90deg, ${choroColor(cho.min, cho.min, cho.max, cho.ramp)}, ${choroColor((cho.min + cho.max) / 2, cho.min, cho.max, cho.ramp)}, ${choroColor(cho.max, cho.min, cho.max, cho.ramp)})`;
          const noDataNames = cho.regions.filter((r) => r.value === null || r.value === undefined).map((r) => r.name);
          const svgUrl = `${chartDownloadBase}/${fileName}.svg`;
          const lazyMap = visualIndex > 0 || !leadFirst;
          return (
            <article class={cardClass(visualIndex, visual, leadFirst)}>
              <div class="viz-head"><div><h2 class="serif">{cho.title}</h2><p>{cleanSubtitle(cho.subtitle, source.sourceId)}</p></div><span>{cho.unit}</span></div>
              <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`} data-svg-url={svgUrl}>
                <button type="button" data-viz-action="svg">SVG</button>
                <button type="button" data-viz-action="csv">CSV</button>
                <button type="button" data-viz-action="share">Share</button>
              </div>
              <div class="choro-wrap">
                {lazyMap ? (
                  <>
                    <div class="lazy-svg-frame choro-map-frame" data-lazy-svg={svgUrl} aria-label={cho.title} style={`aspect-ratio:${viewBoxAspectRatio(cho.viewBox)}`}></div>
                    <noscript><img class="viz-svg choro-map" src={svgUrl} alt={cho.title} loading="lazy" /></noscript>
                  </>
                ) : <Fragment set:html={renderChoroplethSvg(cho)} />}
                <div class="choro-side">
                  <div class="choro-scale">
                    <span class="choro-bar" style={`background:${choGradient}`}></span>
                    <span class="choro-ends"><em>{vf(cho.min)}</em><em>{vf(cho.max)}</em></span>
                    <span class="choro-cap">{cho.unit}</span>
                    {cho.regions.length > valued.length ? <span class="choro-nodata"><i style="background:#efeae4"></i>not surveyed</span> : null}
                  </div>
                  <div class="choro-top">
                    <b>{cho.rankLabel || "Highest"}</b>
                    {top.map((r) => <span><em>{r.name}</em>{vf(r.value)}</span>)}
                  </div>
                  {bottom.length ? (
                    <div class="choro-top choro-bottom">
                      <b>{cho.bottomLabel}</b>
                      {bottom.map((r) => <span><em>{r.name}</em>{vf(r.value)}</span>)}
                    </div>
                  ) : null}
                </div>
              </div>
              {noDataNames.length ? (
                <p class="choro-foot">States shown in grey ({noDataNames.join(", ")}) were not covered by the survey sample, so no estimate exists for them. They are left uncoloured rather than counted as zero.</p>
              ) : null}
              <div class="chart-note">
                <p class="cn-take serif">{note.takeaway}</p>
                {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
                <div class="cn-meta">
                  <p><b>How to read</b><span>{note.howToRead}</span></p>
                  <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
                </div>
              </div>
              <div class="viz-source">
                <span>Source</span>
                {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
              </div>
            </article>
          );
        }

        const pyramid = visual as PyramidVisual;
        const max = Math.max(...pyramid.rows.flatMap((row) => [row.male, row.female]), 1);
        return (
          <article class={cardClass(visualIndex, visual, leadFirst)}>
            <div class="viz-head"><div><h2 class="serif">{pyramid.title}</h2><p>{cleanSubtitle(pyramid.subtitle, source.sourceId)}</p></div><span>{pyramid.year}</span></div>
            <div class="viz-actions" id={chartId} data-file={fileName} data-csv-url={`${chartDownloadBase}/${fileName}.csv`}>
              <button type="button" data-viz-action="csv">CSV</button>
              <button type="button" data-viz-action="share">Share</button>
            </div>
            <div class="pyramid">
              {pyramid.rows.map((row) => (
                <div class="pyr-row">
                  <b class="pyr-num pyr-num-male">{fmt(row.male, pyramid.unit)}</b>
                  <div class="pyr-side male"><i style={`width:${(row.male / max) * 100}%`}></i></div>
                  <span>{row.age}</span>
                  <div class="pyr-side female"><i style={`width:${(row.female / max) * 100}%`}></i></div>
                  <b class="pyr-num pyr-num-female">{fmt(row.female, pyramid.unit)}</b>
                </div>
              ))}
            </div>
            <div class="viz-legend"><span><i style="background:var(--c)"></i>Male</span><span><i style="background:#0b0b0b"></i>Female</span></div>
            <div class="chart-note">
              <p class="cn-take serif">{note.takeaway}</p>
              {note.detail ? <p class="cn-detail">{note.detail}</p> : null}
              <div class="cn-meta">
                <p><b>How to read</b><span>{note.howToRead}</span></p>
                <p><b>Watch out</b><span>{note.mistakeToAvoid}</span></p>
              </div>
            </div>
            <div class="viz-source">
              <span>Source</span>
              {source.sourceUrl ? <a href={source.sourceUrl} target="_blank" rel="noreferrer">{sourceText}</a> : <b>{sourceText}</b>}
            </div>
          </article>
        );
      })}
    </div>
  </section>
) : null}
