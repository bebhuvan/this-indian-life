---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { domainFor, domains, locales } from "../../data/site";
import { questionPages, questionUrl, statusMeta } from "../../data/questions";

export function getStaticPaths() {
  return domains.map((domain) => ({ params: { domain: domain.id } }));
}

const { domain } = Astro.params;
const locale = "en";
const current = domainFor(domain as any)!;
const domainQuestions = questionPages.filter((page) => page.domain === domain);

// Group by readiness so finished pieces aren't mixed in with half-built ones.
// Mirror the Ask page: "Ready to read" vs "Still building" (work-in-progress and
// needs-data both live under the latter, honest rather than hidden).
const statusOrder: Record<string, number> = { ready: 0, work_in_progress: 1, needs_data: 2 };
const sortedQuestions = [...domainQuestions].sort(
  (a, b) =>
    (statusOrder[a.explanation.status] ?? 9) - (statusOrder[b.explanation.status] ?? 9) ||
    a.question.localeCompare(b.question)
);
const questionGroups = [
  { id: "ready", label: "Ready to read", pages: sortedQuestions.filter((p) => p.explanation.status === "ready") },
  { id: "building", label: "Still building", pages: sortedQuestions.filter((p) => p.explanation.status !== "ready") }
];
const featuredReports = domain === "health"
  ? [
      {
        title: "What NFHS-6 reveals about India",
        dek: "A visual reading of the 2023-24 National Family Health Survey: homes, women, fertility, birth, child health, nutrition, chronic disease, ageing, and care.",
        href: `/health/nfhs-6/`,
        meta: "Special report",
      },
    ]
  : [];
---

<Base title={`${current.label} · This Indian Life`} domain={current.id}>
  <div class="wrap">
    <Nav active={current.id} locale={locale} />

    <header class="domain-head">
      <span class="domain-chip"><span class="tk"></span><span>{current.label}</span></span>
      <h1 class="serif">{current.line}</h1>
      <p class="muted">Independent question pages with their own evidence, charts, caveats, and explainers.</p>
    </header>

    {featuredReports.length > 0 && (
      <section class="section featured-reports">
        <p class="sec-hd">Featured report</p>
        <div>
          {featuredReports.map((report) => (
            <a class="q-row report-row" href={report.href}>
              <span class="q-dot" style={`background:var(--${current.id})`}></span>
              <span class="q-txt">
                <span class="report-title">{report.title}</span>
                <span class="report-dek">{report.dek}</span>
              </span>
              <span class="q-ans" style={`color:var(--${current.id}-ink)`}>{report.meta}</span>
              <span class="q-arrow">-></span>
            </a>
          ))}
        </div>
      </section>
    )}

    {questionGroups.map((group) =>
      group.pages.length ? (
        <section class="section">
          <p class="group-hd">{group.label}<span class="sec-count">{group.pages.length}</span></p>
          <div>
            {group.pages.map((page) => (
              <a class="q-row" href={questionUrl(page, locale)}>
                <span class="q-dot" style={`background:var(--${page.domain})`}></span>
                <span class="q-txt">{page.question}</span>
                <span class={`q-ans status ${statusMeta(page.explanation.status).cls}`} style={`color:var(--${page.domain}-ink)`}>{statusMeta(page.explanation.status).short}</span>
                <span class="q-arrow">-></span>
              </a>
            ))}
          </div>
        </section>
      ) : null
    )}

    <Footer locale={locale} />
  </div>
</Base>

<style>
  /* Readiness dividers ("Ready to read" / "Still building") are real headings,
     not the tiny site-wide eyebrow — they organise the whole list. */
  .group-hd {
    display: flex;
    align-items: baseline;
    gap: 13px;
    font-family: var(--serif);
    font-size: 1.55rem;
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink, #0b0b0b);
    margin-bottom: 26px;
  }
  /* Count sits quietly beside the heading, e.g. "Ready to read  5". */
  .sec-count {
    font-family: var(--sans, sans-serif);
    font-size: 0.82rem;
    color: var(--dim, #737373);
    letter-spacing: 0.02em;
    font-variant-numeric: lining-nums tabular-nums;
  }
  .featured-reports {
    padding-bottom: 8px;
  }
  .report-row {
    align-items: flex-start;
    text-decoration: none;
  }
  .report-row .q-txt,
  .report-row .report-dek {
    text-decoration: none;
  }
  .report-row .q-txt {
    display: flex;
    flex-direction: column;
    gap: 7px;
    max-width: 720px;
  }
  .report-title {
    font: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .report-dek {
    font: 300 0.9rem/1.55 "DM Sans", sans-serif;
    color: var(--mid, #5c5c5c);
  }
  .report-row:hover .report-title {
    text-decoration: underline;
  }
  .report-row:hover .report-dek {
    text-decoration: none;
  }
</style>
