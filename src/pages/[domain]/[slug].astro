---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import LineChart from "../../components/LineChart.astro";
import RegisterTabs from "../../components/RegisterTabs.astro";
import {
  chartUrl,
  charts,
  cleanObservations,
  firstObservation,
  formatValue,
  latestObservation,
  loadSeries,
  locales,
  sources
} from "../../data/site";
import { chartGraph } from "../../data/seo";

export function getStaticPaths() {
  return charts.map((chart) => ({
    params: { domain: chart.domain, slug: chart.slug },
    props: { chart }
  }));
}

const locale = "en";
const { chart } = Astro.props;
const series = loadSeries(chart.seriesPath);
const latest = latestObservation(series)!;
const first = firstObservation(series)!;
const observations = cleanObservations(series);
const changeMultiple = first.value !== 0 ? latest.value / first.value : null;
const related = charts.filter((item) => item.id !== chart.id && item.domain === chart.domain).slice(0, 3);
const source = sources[series.sourceId as keyof typeof sources];
---

<Base title={`${chart.title} · This Indian Life`} description={chart.dek} domain={chart.domain} jsonLd={chartGraph(chart, series, locale)}>
  <div class="wrap">
    <Nav active={chart.domain} locale={locale} />

    <header class="chart-head">
      <span class="domain-chip"><span class="tk"></span><span>{chart.domain} · {chart.topic}</span></span>
      <h1 class="serif">{chart.title}</h1>
      <p class="muted">{chart.dek}</p>
    </header>

    <section>
      <div class="chart-toolbar">
        <div class="figrow">
          <span class="fignum">{formatValue(latest.value, chart.valueFormat)}</span>
          <div class="figmeta">
            <span class="delta">{changeMultiple && Number.isFinite(changeMultiple) ? `${changeMultiple.toFixed(1)}x since ${first.date}` : `${observations.length} observations`}</span>
            <span class="since">{series.title} · {latest.date}</span>
          </div>
        </div>
      </div>
      <div class="chart-wrap">
        <LineChart chart={chart} series={series} />
      </div>
      <div class="chart-cap">
        <span class="src"><strong>Source:</strong> <a href={source.api}>{source.name}</a> · indicator {series.sourceIndicatorId}</span>
        <span>Fetched {new Date(series.fetchedAt).toLocaleDateString("en-IN")}</span>
      </div>
    </section>

    <section class="section" style="border-bottom:1px solid var(--ghost)">
      <p class="lbl" style="margin-bottom:24px">At a glance</p>
      <div class="glance-grid">
        <div class="gi"><div class="n">{formatValue(latest.value, chart.valueFormat)}</div><div class="t">latest value, {latest.date}</div></div>
        <div class="gi"><div class="n">{formatValue(first.value, chart.valueFormat)}</div><div class="t">first value, {first.date}</div></div>
        <div class="gi"><div class="n">{observations.length}</div><div class="t">annual observations in this artifact</div></div>
        <div class="gi"><div class="n">{series.frequency}</div><div class="t">source frequency</div></div>
      </div>
    </section>

    <section class="section">
      <div class="layers-top">
        <span class="lbl">The explanation</span>
        <span class="ai-badge"><span class="sp"></span>Draft prose wraps locked source numbers; no numbers are generated at request time</span>
      </div>
      <p class="bottomline">{chart.bottomLine}</p>
      <RegisterTabs chart={chart} />
    </section>

    <section class="section mods">
      <div>
        <p class="lbl" style="margin-bottom:14px">Keep pulling the thread</p>
        {related.length ? related.map((item) => (
          <a class="q-row" href={chartUrl(item, locale)}>
            <span class="q-dot" style={`background:var(--${item.domain})`}></span>
            <span class="q-txt">{item.title}</span>
            <span class="q-arrow">-></span>
          </a>
        )) : <p class="muted">More related charts will appear as this domain grows.</p>}
      </div>
      <div>
        <div class="meth">
          <p class="lbl" style="margin-bottom:4px">Methodology</p>
          <div class="row"><span class="k">Measure</span><span class="v">{series.title}</span></div>
          <div class="row"><span class="k">Geography</span><span class="v">{series.geography.name}</span></div>
          <div class="row"><span class="k">Unit</span><span class="v">{series.unit}</span></div>
          <div class="row"><span class="k">Transform</span><span class="v">{chart.methodology.transformations[0]}</span></div>
          <div class="row"><span class="k">Caveat</span><span class="v">{chart.methodology.caveats[0]}</span></div>
        </div>
      </div>
    </section>
  </div>
</Base>
