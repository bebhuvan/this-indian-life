---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import ArticleVisuals from "../../components/ArticleVisuals.astro";
import ConceptPrimer from "../../components/ConceptPrimer.astro";
import EditorialStory from "../../components/EditorialStory.astro";
import ArticleEditLog from "../../components/ArticleEditLog.astro";
import ArticleEvidence from "../../components/ArticleEvidence.astro";
import Footer from "../../components/Footer.astro";
import { locales } from "../../data/site";
import { annotateStorySections, inlineMarkdownHtml, keyGlossaryTerms, macchaExplanation, markdownBlocks, pullQuoteForPage, questionPages, questionUrl, statusMeta } from "../../data/questions";
import { visualsForQuestion, bindSectionVisuals } from "../../data/viz";
import { articleGraph } from "../../data/seo";

export function getStaticPaths() {
  return questionPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const locale = "en";
const { page } = Astro.props;
const explanation = page.explanation;
const related = questionPages.filter((item) => item.id !== page.id && item.domain === page.domain).slice(0, 4);
const blocks = markdownBlocks(explanation.article.bodyMarkdown);
const updatedLabel = explanation.generatedAt
  ? new Date(explanation.generatedAt).toLocaleDateString("en-US", { month: "long", year: "numeric" })
  : null;
const status = statusMeta(explanation.status);
// Curated plan decides which charts show and at what size. The page reads as a
// narrative: an opening answer + hero chart, then prose sections each interleaved
// with the chart they discuss. The lead (core indicator) chart opens the story.
const visuals = visualsForQuestion(page);
// Bind ALL charts to sections via the map (including the hero) so the section that
// maps to the lead chart actually receives it. Sizing (hero/feature/small) is carried
// on each visual, so the lead still renders large in its section.
const storyVisuals = visuals;
const maccha = macchaExplanation(page);
// The "tell me what this means, bro" block: prefer the LLM-written version, fall
// back to the template. It now lives AFTER the data, where the question naturally arises.
const llmMacha = (explanation as { macha?: { heading?: string; body?: string; soWhat?: string } }).macha;
const machaBlock = llmMacha?.heading
  ? { heading: llmMacha.heading, body: llmMacha.body || "", soWhat: llmMacha.soWhat || "" }
  : { heading: maccha.title, body: maccha.body, soWhat: maccha.bullets?.[0] || "" };
const pullQuote = pullQuoteForPage(page);
const editorialStory = explanation.editorialStory;

type MarkdownBlock = ReturnType<typeof markdownBlocks>[number];
const storySections: Array<{ heading: string; blocks: MarkdownBlock[] }> = [];
let currentSection: { heading: string; blocks: MarkdownBlock[] } | null = null;
for (const block of blocks) {
  if (block.type === "h2") {
    if (currentSection) storySections.push(currentSection);
    currentSection = { heading: block.text, blocks: [] };
  } else if (currentSection) {
    currentSection.blocks.push(block);
  } else {
    currentSection = { heading: explanation.article.title, blocks: [block] };
  }
}
if (currentSection) storySections.push(currentSection);

// Pair each prose section with the chart it discusses. The LLM's sectionVisualMap
// (heading -> visualId) wins; otherwise a token-overlap heuristic. Unbound charts
// fall to a compact grid at the end so nothing high-signal is dropped.
const sectionInputs = storySections.map((section) => ({
  heading: section.heading,
  text: section.blocks.filter((block) => block.type === "p").map((block) => block.text).join(" ")
}));
const explicitMap = Object.fromEntries(
  ((explanation as { sectionVisualMap?: Array<{ heading: string; visualId: string }> }).sectionVisualMap || [])
    .map((entry) => [entry.heading, entry.visualId])
);
const { bound: boundVisuals, leftover: leftoverVisuals } = bindSectionVisuals(sectionInputs, storyVisuals, explicitMap);

// Inline glossary: define jargon where the reader meets it. Every glossary term
// gets a tappable popover on first mention; the load-bearing terms (named in the
// headline/dek) get an inline definition box instead. Chart-binding above still
// uses the original storySections, so this only changes how prose renders.
const glossaryBlocks = explanation.editorialPlan?.glossaryBlocks ?? [];
const keyTerms = keyGlossaryTerms(glossaryBlocks, `${explanation.short.headline} ${explanation.short.dek}`);
const annotatedSections = annotateStorySections(storySections, glossaryBlocks, keyTerms);
---

<Base title={`${page.question} · This Indian Life`} description={explanation.short.dek} domain={page.domain} ogType="article" image={`/og/articles/${page.slug}.png`} jsonLd={articleGraph(page, locale)} markdownUrl={`/articles/${page.slug}.md`}>
  <div class={`wrap${page.slug === "india-and-gold" ? " theme-gold" : ""}`}>
    <Nav active={page.domain} locale={locale} />

    <header class="article-head">
      <span class="domain-chip"><span class="tk"></span><span>{page.domain} · V1 question</span></span>
      <h1 class="serif">{page.question}</h1>
      <p class="muted">{explanation.short.dek}</p>
      <div class="article-status">
        <span class={`status ${status.cls}`}>{status.label}</span>
        {explanation.lastReviewed
          ? <span>Last reviewed {explanation.lastReviewed}</span>
          : (updatedLabel ? <span>Updated {updatedLabel}</span> : null)}
        {explanation.dataThrough ? <span>Data through {explanation.dataThrough}</span> : null}
      </div>
    </header>

    {editorialStory ? (
      <nav class="article-tabs article-tabs--views" aria-label="Article views" data-article-tablist>
        <button class="article-tab is-active" data-article-tab="data" type="button" aria-selected="true">Article</button>
        <button class="article-tab" data-article-tab="essay" type="button" aria-selected="false">Essay</button>
        <button class="article-tab" data-article-tab="evidence" type="button" aria-selected="false">Evidence</button>
      </nav>
    ) : null}

    <section class="article-hero single">
      <div class="explain-card standard">
        <p class="lbl">Short answer</p>
        <h2 class="serif">{explanation.short.headline}</h2>
        <p>{explanation.short.body}</p>
      </div>
    </section>

    <section class="data-pull">
      <p class="lbl">The point</p>
      <div>
        <span class="serif">{pullQuote.stat}</span>
        <p class="serif">{pullQuote.line}</p>
      </div>
    </section>

    {page.primer ? <ConceptPrimer primer={page.primer} domain={page.domain} /> : null}

    {editorialStory ? (
      <>
        <section class="article-panel" data-article-panel="data">
          <section class="section article-story-section" id="charts">
            <article class="article-body story-body">
              <p class="lbl">Guided story</p>
              <h2 class="serif">{explanation.article.title}</h2>
              <p class="standfirst">{explanation.article.standfirst}</p>
              <div class="story-flow">
                {annotatedSections.map((section, index) => (
                  <section class={`story-step ${(boundVisuals[index] as { size?: string } | null)?.size === "small" ? "story-step--small" : "story-step--feature"}`}>
                    <div class="story-copy longform">
                      <h3>{section.heading}</h3>
                      {section.blocks.map((block) => {
                        if (block.type === "h3") return <h4>{block.text}</h4>;
                        if (block.type === "defbox") return (<aside class="defbox"><p class="defbox-lbl">Definition</p><p class="defbox-term">{block.item.term}</p><p class="defbox-mean">{block.item.plainMeaning}</p>{block.item.whyItMattersHere ? <p class="defbox-why">{block.item.whyItMattersHere}</p> : null}</aside>);
                        if (block.type === "p") return <p set:html={block.html ?? inlineMarkdownHtml(block.text)} />;
                        if (block.type === "ul") {
                          return (
                            <ul class="story-list">
                              {(block.htmlItems ?? block.items.map((it) => inlineMarkdownHtml(it))).map((item) => <li set:html={item} />)}
                            </ul>
                          );
                        }
                        if (block.type === "table") {
                          return (
                            <div class="story-table-wrap">
                              <table class="story-table">
                                <thead>
                                  <tr>{block.headers.map((header) => <th set:html={inlineMarkdownHtml(header)} />)}</tr>
                                </thead>
                                <tbody>
                                  {block.rows.map((row) => (
                                    <tr>{row.map((cell) => <td set:html={inlineMarkdownHtml(cell)} />)}</tr>
                                  ))}
                                </tbody>
                              </table>
                            </div>
                          );
                        }
                        return null;
                      })}
                    </div>
                    {boundVisuals[index] ? (
                      <ArticleVisuals
                        visuals={[boundVisuals[index]]}
                        lockedNumbers={explanation.evidence.lockedNumbers}
                        chartExplainers={explanation.chartExplainers}
                        showKpis={false}
                        leadFirst={false}
                        startIndex={index + 1}
                        sectionLabel={`Chart ${index + 2}`}
                        sectionClass="story-viz"
                      />
                    ) : null}
                  </section>
                ))}
                {leftoverVisuals.length ? (
                  <ArticleVisuals
                    visuals={leftoverVisuals}
                    lockedNumbers={explanation.evidence.lockedNumbers}
                    chartExplainers={explanation.chartExplainers}
                    showKpis={false}
                    leadFirst={false}
                    startIndex={storySections.length + 1}
                    sectionLabel="More from the data"
                    sectionClass="story-viz story-leftover"
                  />
                ) : null}
              </div>
              {explanation.editorialPlan?.glossaryBlocks?.length ? (
                <section class="concept-blocks">
                  <p class="lbl">Plain English concepts</p>
                  {explanation.editorialPlan.glossaryBlocks.map((item) => (
                    <div class="concept-item">
                      <h3 class="serif">{item.term}</h3>
                      <p>{item.plainMeaning}</p>
                      <p class="concept-why">{item.whyItMattersHere}</p>
                    </div>
                  ))}
                </section>
              ) : null}
            </article>
          </section>

          <section class="macha-block">
            <p class="lbl">Tell me what this means, bro</p>
            <h2 class="serif">{machaBlock.heading}</h2>
            <p class="macha-body">{machaBlock.body}</p>
            {machaBlock.soWhat ? <p class="macha-sowhat serif">{machaBlock.soWhat}</p> : null}
          </section>
        </section>

        <section class="article-panel article-panel-story" data-article-panel="essay" hidden>
          <EditorialStory story={editorialStory} lockedNumbers={explanation.evidence.lockedNumbers} />
        </section>

        <section class="article-panel" data-article-panel="evidence" hidden>
          <section class="section article-meta-section" id="evidence">
            <ArticleEvidence explanation={explanation} />
          </section>
        </section>

        <script is:inline>
          (() => {
            const tablist = document.querySelector("[data-article-tablist]");
            if (!tablist) return;
            const tabs = Array.from(document.querySelectorAll("[data-article-tab]"));
            const panels = Array.from(document.querySelectorAll("[data-article-panel]"));
            const valid = new Set(panels.map((panel) => panel.getAttribute("data-article-panel")));
            function show(id, updateUrl = true, scroll = true) {
              const target = valid.has(id) ? id : "data";
              panels.forEach((panel) => {
                panel.hidden = panel.getAttribute("data-article-panel") !== target;
              });
              tabs.forEach((tab) => {
                const active = tab.getAttribute("data-article-tab") === target;
                tab.classList.toggle("is-active", active);
                tab.setAttribute("aria-selected", active ? "true" : "false");
              });
              if (updateUrl) {
                const url = new URL(window.location.href);
                if (target === "data") url.searchParams.delete("view");
                else url.searchParams.set("view", target);
                history.replaceState(null, "", url);
              }
              if (scroll) {
                if (target === "data") window.scrollTo({ top: 0, behavior: "smooth" });
                else tablist.scrollIntoView({ block: "start", behavior: "smooth" });
              }
            }
            tabs.forEach((tab) => {
              tab.addEventListener("click", () => show(tab.getAttribute("data-article-tab")));
            });
            const initial = new URL(window.location.href).searchParams.get("view");
            show(initial && valid.has(initial) ? initial : "data", false, false);
          })();
        </script>
      </>
    ) : (
      <>
        <section class="section article-story-section" id="charts">
          <article class="article-body story-body">
            <p class="lbl">Guided story</p>
            <h2 class="serif">{explanation.article.title}</h2>
            <p class="standfirst">{explanation.article.standfirst}</p>
            <div class="story-flow">
              {annotatedSections.map((section, index) => (
                <section class={`story-step ${(boundVisuals[index] as { size?: string } | null)?.size === "small" ? "story-step--small" : "story-step--feature"}`}>
                  <div class="story-copy longform">
                    <h3>{section.heading}</h3>
                    {section.blocks.map((block) => {
                      if (block.type === "h3") return <h4>{block.text}</h4>;
                      if (block.type === "defbox") return (<aside class="defbox"><p class="defbox-lbl">Definition</p><p class="defbox-term">{block.item.term}</p><p class="defbox-mean">{block.item.plainMeaning}</p>{block.item.whyItMattersHere ? <p class="defbox-why">{block.item.whyItMattersHere}</p> : null}</aside>);
                        if (block.type === "p") return <p set:html={block.html ?? inlineMarkdownHtml(block.text)} />;
                      if (block.type === "ul") {
                        return (
                          <ul class="story-list">
                            {(block.htmlItems ?? block.items.map((it) => inlineMarkdownHtml(it))).map((item) => <li set:html={item} />)}
                          </ul>
                        );
                      }
                      if (block.type === "table") {
                        return (
                          <div class="story-table-wrap">
                            <table class="story-table">
                              <thead>
                                <tr>{block.headers.map((header) => <th set:html={inlineMarkdownHtml(header)} />)}</tr>
                              </thead>
                              <tbody>
                                {block.rows.map((row) => (
                                  <tr>{row.map((cell) => <td set:html={inlineMarkdownHtml(cell)} />)}</tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                        );
                      }
                      return null;
                    })}
                  </div>
                  {boundVisuals[index] ? (
                    <ArticleVisuals
                      visuals={[boundVisuals[index]]}
                      lockedNumbers={explanation.evidence.lockedNumbers}
                      chartExplainers={explanation.chartExplainers}
                      showKpis={false}
                      leadFirst={false}
                      startIndex={index + 1}
                      sectionLabel={`Chart ${index + 2}`}
                      sectionClass="story-viz"
                    />
                  ) : null}
                </section>
              ))}
              {leftoverVisuals.length ? (
                <ArticleVisuals
                  visuals={leftoverVisuals}
                  lockedNumbers={explanation.evidence.lockedNumbers}
                  chartExplainers={explanation.chartExplainers}
                  showKpis={false}
                  leadFirst={false}
                  startIndex={storySections.length + 1}
                  sectionLabel="More from the data"
                  sectionClass="story-viz story-leftover"
                />
              ) : null}
            </div>
          </article>
        </section>

        <section class="macha-block">
          <p class="lbl">Tell me what this means, bro</p>
          <h2 class="serif">{machaBlock.heading}</h2>
          <p class="macha-body">{machaBlock.body}</p>
          {machaBlock.soWhat ? <p class="macha-sowhat serif">{machaBlock.soWhat}</p> : null}
        </section>

        <section class="section article-meta-section" id="evidence">
          <ArticleEvidence explanation={explanation} />
        </section>
      </>
    )}

    <section class="section">
      <p class="sec-hd">Related questions</p>
      {related.map((item) => (
        <a class="q-row" href={questionUrl(item, locale)}>
          <span class="q-dot" style={`background:var(--${item.domain})`}></span>
          <span class="q-txt">{item.question}</span>
          <span class="q-arrow">-></span>
        </a>
      ))}
    </section>

    <ArticleEditLog questionId={page.id} explanation={explanation} />

    <Footer locale={locale} />
    <script src="/article-actions.js" defer></script>
  </div>
  <script>
    // Inline glossary terms: tap to toggle the definition popover (touch), with
    // keyboard support; CSS handles hover/focus on pointer devices.
    (() => {
      const closeAll = (except) => document.querySelectorAll('.defterm[aria-expanded="true"]')
        .forEach((el) => { if (el !== except) el.setAttribute("aria-expanded", "false"); });
      document.addEventListener("click", (e) => {
        const term = (e.target instanceof Element) ? e.target.closest(".defterm") : null;
        closeAll(term);
        if (term) {
          const open = term.getAttribute("aria-expanded") === "true";
          term.setAttribute("aria-expanded", open ? "false" : "true");
          e.preventDefault();
        }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") return closeAll(null);
        const el = document.activeElement;
        if (el && el.classList && el.classList.contains("defterm") && (e.key === "Enter" || e.key === " ")) {
          const open = el.getAttribute("aria-expanded") === "true";
          el.setAttribute("aria-expanded", open ? "false" : "true");
          e.preventDefault();
        }
      });
    })();
  </script>
</Base>
