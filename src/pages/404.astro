---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const locale = "en";
---

<Base title="Not found · This Indian Life" description="That page doesn't exist on This Indian Life.">
  <div class="wrap">
    <Nav locale={locale} />

    <header class="domain-head">
      <span class="lbl">404</span>
      <h1 class="serif">That page wandered off.</h1>
      <p class="muted">
        The page you're looking for doesn't exist — it may have moved, or never existed.
        Here's the way back.
      </p>
    </header>

    <section class="section">
      <a class="q-row" href="/">
        <span class="q-dot" style="background:var(--economy)"></span>
        <span class="q-txt">Back to the homepage</span>
        <span class="q-arrow">-></span>
      </a>
      <a class="q-row" href={`/articles/`}>
        <span class="q-dot" style="background:var(--people)"></span>
        <span class="q-txt">Browse and search every question</span>
        <span class="q-arrow">-></span>
      </a>
    </section>

    <Footer locale={locale} />
  </div>
</Base>
